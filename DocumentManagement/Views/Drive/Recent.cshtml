@model List<DocumentManagement.Models.FileModel>

@{
    ViewBag.Title = "Recent Files";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Layout 2 cột */
    .drive-layout {
        display: flex;
        gap: 24px;
        align-items: flex-start;
    }

    /* Sidebar cố định, không bị cuộn */
    .drive-sidebar {
        width: 260px;
        flex-shrink: 0;
        background: white;
        border-radius: 16px;
        padding: 20px;
        border: 1px solid #E0E0E0;
        position: sticky;
        top: 100px;
        align-self: flex-start;
        max-height: calc(100vh - 120px);
        overflow-y: auto;
    }

        .drive-sidebar::-webkit-scrollbar {
            width: 4px;
        }

        .drive-sidebar::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 4px;
        }

        .drive-sidebar::-webkit-scrollbar-thumb {
            background: #ccc;
            border-radius: 4px;
        }

        .drive-sidebar .menu-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: 12px;
            color: #666;
            transition: all 0.2s;
            cursor: pointer;
            margin-bottom: 4px;
        }

            .drive-sidebar .menu-item i {
                width: 24px;
                font-size: 18px;
            }

            .drive-sidebar .menu-item:hover {
                background: #F5F5F5;
                color: #00BCD4;
            }

            .drive-sidebar .menu-item.active {
                background: #00BCD4;
                color: white;
            }

    /* Nội dung chính */
    .drive-content {
        flex: 1;
        min-width: 0;
    }

    .section-title {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 16px;
        color: #212121;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .section-title i {
            color: #00BCD4;
        }

    .file-table {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #E0E0E0;
    }

        .file-table th {
            background: #F8F9FA;
            padding: 14px 16px;
            font-weight: 600;
            font-size: 13px;
            color: #666;
            border-bottom: 1px solid #E0E0E0;
        }

        .file-table td {
            padding: 14px 16px;
            border-bottom: 1px solid #F0F0F0;
        }

    .file-row:hover {
        background: #F8F9FA;
    }

    .file-icon {
        font-size: 24px;
        margin-right: 12px;
    }

    .file-actions {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
    }

        .file-actions button, .file-actions a {
            background: none;
            border: none;
            color: #999;
            cursor: pointer;
            padding: 4px;
            border-radius: 6px;
        }

            .file-actions button:hover, .file-actions a:hover {
                background: #F0F0F0;
                color: #00BCD4;
            }

    .star-active {
        color: #FFC107 !important;
    }

    .empty-message {
        text-align: center;
        padding: 60px;
        background: white;
        border-radius: 12px;
        color: #999;
    }

        .empty-message i {
            font-size: 48px;
            margin-bottom: 16px;
            opacity: 0.5;
        }

    /* Modal */
    /* Modal đẹp */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        visibility: hidden;
        opacity: 0;
        transition: all 0.25s ease;
    }

        .modal-overlay.active {
            visibility: visible;
            opacity: 1;
        }

    .modal-container {
        background: white;
        border-radius: 24px;
        width: 440px;
        max-width: 90%;
        padding: 0;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        transform: scale(0.95);
        transition: transform 0.25s cubic-bezier(0.34, 1.2, 0.64, 1);
        overflow: hidden;
    }

    .modal-overlay.active .modal-container {
        transform: scale(1);
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 24px;
        background: #f8fafc;
        border-bottom: 1px solid #eef2f6;
    }

        .modal-header h3 {
            font-size: 18px;
            font-weight: 600;
            margin: 0;
            color: #1e293b;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .modal-header h3 i {
                color: #00BCD4;
                font-size: 20px;
            }

    .modal-close {
        background: none;
        border: none;
        font-size: 20px;
        cursor: pointer;
        color: #94a3b8;
        transition: all 0.2s;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
    }

        .modal-close:hover {
            background: #f1f5f9;
            color: #1e293b;
        }

    .modal-body {
        padding: 24px;
    }

        .modal-body p {
            margin: 0 0 8px 0;
            color: #334155;
            line-height: 1.5;
        }

        .modal-body strong {
            color: #00BCD4;
        }

        .modal-body input {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            font-size: 14px;
            transition: all 0.2s;
            background: #fff;
        }

            .modal-body input:focus {
                outline: none;
                border-color: #00BCD4;
                box-shadow: 0 0 0 3px rgba(0, 188, 212, 0.1);
            }

        .modal-body small {
            display: block;
            margin-top: 8px;
            color: #64748b;
            font-size: 12px;
        }

    .modal-footer {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
        padding: 16px 24px 24px 24px;
        background: #fff;
        border-top: 1px solid #f1f5f9;
    }

    .btn-modal-cancel {
        padding: 10px 20px;
        background: #f1f5f9;
        border: none;
        border-radius: 12px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 500;
        color: #475569;
        transition: all 0.2s;
    }

        .btn-modal-cancel:hover {
            background: #e2e8f0;
            color: #1e293b;
        }

    .btn-modal-confirm {
        padding: 10px 24px;
        background: #00BCD4;
        color: white;
        border: none;
        border-radius: 12px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 500;
        transition: all 0.2s;
    }

        .btn-modal-confirm:hover {
            background: #0097a7;
            transform: translateY(-1px);
        }

        .btn-modal-confirm.delete {
            background: #ef4444;
        }

            .btn-modal-confirm.delete:hover {
                background: #dc2626;
            }
</style>

<div class="drive-layout">
    <!-- Sidebar -->
    <div class="drive-sidebar">
        <div class="menu-item" onclick="location.href='@Url.Action("Index", "Drive")'">
            <i class="fas fa-cloud"></i> My Drive
        </div>
        <div class="menu-item active" onclick="location.href='@Url.Action("Recent", "Drive")'">
            <i class="fas fa-clock"></i> Recent
        </div>
        <div class="menu-item" onclick="location.href='@Url.Action("Starred", "Drive")'">
            <i class="fas fa-star"></i> Starred
        </div>
        <div class="menu-item" onclick="location.href='@Url.Action("Trash", "Drive")'">
            <i class="fas fa-trash"></i> Trash
        </div>
    </div>

    <!-- Nội dung chính -->
    <div class="drive-content">
        <div class="section-title">
            <i class="fas fa-clock"></i> Recent Files
        </div>

        @if (Model.Count == 0)
        {
            <div class="empty-message">
                <i class="fas fa-inbox" style="font-size: 48px; margin-bottom: 16px; opacity: 0.5;"></i>
                <p>Chưa có file nào được tải lên gần đây</p>
            </div>
        }
        else
        {
            <div class="file-table">
                <table style="width:100%">
                    <thead>
                        <tr>
                            <th>Tên file</th>
                            <th>Kích thước</th>
                            <th>Ngày tải lên</th>
                            <th style="text-align:right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var file in Model)
                        {
                            <tr class="file-row">
                                <td>
                                    <i class="fas @(file.FileType == "pdf" ? "fa-file-pdf" : file.FileType == "docx" ? "fa-file-word" : file.FileType == "xlsx" ? "fa-file-excel" : "fa-file") file-icon"
                                       style="color:@(file.FileType == "pdf" ? "#DC3545" : file.FileType == "docx" ? "#0D6EFD" : file.FileType == "xlsx" ? "#198754" : "#6C757D")"></i>
                                    @file.FileName
                                    @if (file.IsStarred)
                                    {<i class="fas fa-star" style="color:#FFC107; margin-left:8px"></i>}
                                </td>
                                <td>@file.FormattedSize</td>
                                <td>@file.UploadedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td style="text-align:right">
                                    <div class="file-actions">
                                        @if (file.FileType == "pdf")
                                        {
                                            <a href="@Url.Action("PreviewPDF", "Drive", new { id = file.ID })" target="_blank" title="Xem trước">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        }
                                        <a href="@Url.Action("Download", "Drive", new { id = file.ID })" title="Tải xuống">
                                            <i class="fas fa-download"></i>
                                        </a>
                                        <button class="share-file" data-id="@file.ID" title="Chia sẻ">
                                            <i class="fas fa-share-alt"></i>
                                        </button>
                                        <button class="delete-file" data-id="@file.ID" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                        <button class="star-file" data-id="@file.ID" title="@(file.IsStarred ? "Bỏ sao" : "Đánh dấu sao")">
                                            <i class="fas fa-star @(file.IsStarred ? "star-active" : "")"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<script>
    // Xóa file
    document.querySelectorAll('.delete-file').forEach(btn => btn.onclick = e => {
        e.stopPropagation();
        if (confirm('Xóa file?')) {
            fetch('/Drive/Delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + btn.dataset.id
            }).then(() => location.reload());
        }
    });

    // Share file
    document.querySelectorAll('.share-file').forEach(btn => btn.onclick = e => {
        e.stopPropagation();
        let pwd = prompt('Mật khẩu (tùy chọn):');
        fetch('/Drive/CreateShareLink', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'fileId=' + btn.dataset.id + '&password=' + encodeURIComponent(pwd || '')
        }).then(r => r.json()).then(d => {
            if (d.success) prompt('Link:', d.url);
            else alert(d.message);
        });
    });

    // Star file
    document.querySelectorAll('.star-file').forEach(btn => btn.onclick = e => {
        e.stopPropagation();
        fetch('/Drive/ToggleStar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'id=' + btn.dataset.id
        }).then(() => location.reload());
    });
</script>

