@{
    ViewBag.Title = "Xem trước PDF";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string filePath = ViewBag.FilePath;
    string fileName = ViewBag.FileName;
    int fileId = ViewBag.FileID;
}

<style>
    :root {
        --primary: #00BCD4;
        --primary-dark: #0097A7;
        --text-dark: #212121;
        --text-light: #666666;
        --bg-gray: #F5F5F5;
        --white: #FFFFFF;
        --border: #E0E0E0;
    }

    .pdf-container {
        max-width: 1200px;
        margin: 0 auto;
        background: var(--white);
        border-radius: 24px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .pdf-header {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        padding: 20px 24px;
        color: white;
    }

        .pdf-header h2 {
            margin: 0;
            font-size: 20px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .pdf-header h2 i {
                font-size: 28px;
            }

    .pdf-toolbar {
        background: var(--white);
        padding: 16px 24px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

        .pdf-toolbar button {
            padding: 8px 16px;
            border: 1px solid var(--border);
            background: var(--white);
            border-radius: 40px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--text-dark);
        }

            .pdf-toolbar button:hover {
                background: var(--primary);
                border-color: var(--primary);
                color: white;
            }

        .pdf-toolbar .page-info {
            background: var(--bg-gray);
            padding: 8px 16px;
            border-radius: 40px;
            font-size: 14px;
            font-weight: 500;
            color: var(--text-dark);
        }

    .pdf-viewer {
        background: var(--bg-gray);
        padding: 24px;
        min-height: 600px;
        text-align: center;
        overflow: auto;
    }

    canvas {
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        margin: 0 auto;
        display: block;
        border-radius: 8px;
    }

    .loading {
        text-align: center;
        padding: 60px;
        color: var(--text-light);
    }

        .loading i {
            font-size: 48px;
            margin-bottom: 16px;
            color: var(--primary);
        }

    .btn-download {
        background: var(--primary);
        color: white;
        border: none;
    }

        .btn-download:hover {
            background: var(--primary-dark);
        }
</style>

<div class="pdf-container">
    <div class="pdf-header">
        <h2>
            <i class="fas fa-file-pdf"></i>
            @fileName
        </h2>
    </div>

    <div class="pdf-toolbar">
        <button id="prev-page">
            <i class="fas fa-chevron-left"></i> Trang trước
        </button>
        <span class="page-info">
            Trang <span id="current-page">1</span> / <span id="total-pages">...</span>
        </span>
        <button id="next-page">
            Trang sau <i class="fas fa-chevron-right"></i>
        </button>
        <div style="flex:1"></div>
        <button id="zoom-in">
            <i class="fas fa-search-plus"></i> Phóng to
        </button>
        <button id="zoom-out">
            <i class="fas fa-search-minus"></i> Thu nhỏ
        </button>
        <a href="@Url.Action("Download", "Drive", new { id = fileId })" class="btn-download" style="text-decoration: none;">
            <i class="fas fa-download"></i> Tải xuống
        </a>
    </div>

    <div class="pdf-viewer" id="pdf-container">
        <div class="loading">
            <i class="fas fa-spinner fa-spin"></i>
            <p>Đang tải PDF...</p>
        </div>
        <canvas id="pdf-canvas"></canvas>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js"></script>
<script>
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';

    var pdfDoc = null;
    var currentPage = 1;
    var scale = 1.2;
    var canvas = document.getElementById('pdf-canvas');
    var ctx = canvas.getContext('2d');
    var filePath = decodeURIComponent('@Html.Raw(Url.Encode(filePath))');

    function getPdfUrl() {
        return '@Url.Action("GetPdfFile", "Drive")' + '?filePath=' + encodeURIComponent(filePath);
    }

    function loadPdf() {
    var loadingDiv = document.querySelector('.loading');
    var url = '@Url.Action("GetPdfFile", "Drive")' + '?filePath=' + encodeURIComponent(filePath);

    // Dùng fetch để lấy file dạng blob
    fetch(url, {
        credentials: 'same-origin'
    })
    .then(response => response.blob())
    .then(blob => {
        var blobUrl = URL.createObjectURL(blob);
        return pdfjsLib.getDocument(blobUrl).promise;
    })
    .then(function(pdf) {
        pdfDoc = pdf;
        document.getElementById('total-pages').textContent = pdfDoc.numPages;
        loadingDiv.style.display = 'none';
        renderPage(currentPage);
    })
    .catch(function(error) {
        console.error('Lỗi tải PDF:', error);
        loadingDiv.innerHTML = '<div class="alert alert-danger">Không thể tải file PDF. Lỗi: ' + error.message + '</div>';
    });
}

    function renderPage(pageNum) {
        pdfDoc.getPage(pageNum).then(function(page) {
            var viewport = page.getViewport({ scale: scale });
            canvas.height = viewport.height;
            canvas.width = viewport.width;
            page.render({ canvasContext: ctx, viewport: viewport });
            document.getElementById('current-page').textContent = pageNum;
        });
    }

    function goPrevPage() { if (currentPage > 1) { currentPage--; renderPage(currentPage); } }
    function goNextPage() { if (currentPage < pdfDoc.numPages) { currentPage++; renderPage(currentPage); } }
    function zoomIn() { scale += 0.2; renderPage(currentPage); }
    function zoomOut() { if (scale > 0.4) { scale -= 0.2; renderPage(currentPage); } }

    document.addEventListener('DOMContentLoaded', function() {
        loadPdf();
        document.getElementById('prev-page').addEventListener('click', goPrevPage);
        document.getElementById('next-page').addEventListener('click', goNextPage);
        document.getElementById('zoom-in').addEventListener('click', zoomIn);
        document.getElementById('zoom-out').addEventListener('click', zoomOut);
        document.addEventListener('keydown', function(e) {
            if (e.key === 'ArrowLeft') { goPrevPage(); e.preventDefault(); }
            else if (e.key === 'ArrowRight') { goNextPage(); e.preventDefault(); }
        });
    });
</script>