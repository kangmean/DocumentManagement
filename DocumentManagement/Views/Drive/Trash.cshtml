@model List<DocumentManagement.Models.FileModel>

@{
    ViewBag.Title = "Trash";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Copy toàn bộ CSS từ Starred vào đây (giống hệt) */
    .drive-layout {
        display: flex;
        gap: 24px;
        align-items: flex-start;
    }

    .drive-sidebar {
        width: 260px;
        flex-shrink: 0;
        background: white;
        border-radius: 16px;
        padding: 20px;
        border: 1px solid #E0E0E0;
        position: sticky;
        top: 100px;
        align-self: flex-start;
        max-height: calc(100vh - 120px);
        overflow-y: auto;
    }

        .drive-sidebar::-webkit-scrollbar {
            width: 4px;
        }

        .drive-sidebar::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 4px;
        }

        .drive-sidebar::-webkit-scrollbar-thumb {
            background: #ccc;
            border-radius: 4px;
        }

        .drive-sidebar .menu-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: 12px;
            color: #666;
            transition: all 0.2s;
            cursor: pointer;
            margin-bottom: 4px;
        }

            .drive-sidebar .menu-item i {
                width: 24px;
                font-size: 18px;
            }

            .drive-sidebar .menu-item:hover {
                background: #F5F5F5;
                color: #00BCD4;
            }

            .drive-sidebar .menu-item.active {
                background: #00BCD4;
                color: white;
            }

    .drive-content {
        flex: 1;
        min-width: 0;
    }

    .section-title {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 16px;
        color: #212121;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .section-title i {
            color: #00BCD4;
        }

    .file-table {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #E0E0E0;
    }

        .file-table th {
            background: #F8F9FA;
            padding: 14px 16px;
            font-weight: 600;
            font-size: 13px;
            color: #666;
            border-bottom: 1px solid #E0E0E0;
        }

        .file-table td {
            padding: 14px 16px;
            border-bottom: 1px solid #F0F0F0;
        }

    .file-row:hover {
        background: #F8F9FA;
    }

    .file-icon {
        font-size: 24px;
        margin-right: 12px;
    }

    .file-actions {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
    }

        .file-actions button, .file-actions a {
            background: none;
            border: none;
            color: #999;
            cursor: pointer;
            padding: 4px;
            border-radius: 6px;
        }

            .file-actions button:hover, .file-actions a:hover {
                background: #F0F0F0;
                color: #00BCD4;
            }

    .empty-message {
        text-align: center;
        padding: 60px;
        background: white;
        border-radius: 12px;
        color: #999;
    }


</style>

<div class="drive-layout">
    <div class="drive-sidebar">
        <div class="menu-item" onclick="location.href='@Url.Action("Index", "Drive")'">
            <i class="fas fa-cloud"></i> My Drive
        </div>
        <div class="menu-item" onclick="location.href='@Url.Action("Recent", "Drive")'">
            <i class="fas fa-clock"></i> Recent
        </div>
        <div class="menu-item" onclick="location.href='@Url.Action("Starred", "Drive")'">
            <i class="fas fa-star"></i> Starred
        </div>
        <div class="menu-item active" onclick="location.href='@Url.Action("Trash", "Drive")'">
            <i class="fas fa-trash"></i> Trash
        </div>
    </div>

    <div class="drive-content">
        <div class="section-title">
            <i class="fas fa-trash"></i> Trash
        </div>

        @if (Model.Count == 0)
        {
            <div class="empty-message">
                <i class="fas fa-trash"></i>
                <p>Thùng rác trống</p>
            </div>
        }
        else
        {
            <div class="file-table">
                <table style="width:100%">
                    <thead>
                        <tr>
                            <th>Tên file</th>
                            <th>Kích thước</th>
                            <th>Ngày xóa</th>
                            <th style="text-align:right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var file in Model)
                        {
                            <tr class="file-row">
                                <td>
                                    <i class="fas @(file.FileType == "pdf" ? "fa-file-pdf" : "fa-file") file-icon"
                                       style="color:@(file.FileType == "pdf" ? "#DC3545" : "#6C757D")"></i>
                                    @file.FileName
                                </td>
                                <td>@file.FormattedSize</td>
                                <td>@(file.DeletedAt?.ToString("dd/MM/yyyy HH:mm") ?? "")</td>
                                <td style="text-align:right">
                                    <div class="file-actions">
                                        <button class="restore-file" data-id="@file.ID"><i class="fas fa-trash-restore"></i></button>
                                        <button class="delete-forever" data-id="@file.ID"><i class="fas fa-trash-alt"></i></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<script>
    document.querySelectorAll('.restore-file').forEach(btn => btn.onclick = e => {
        e.stopPropagation();
        if (confirm('Khôi phục file này?')) {
            fetch('/Drive/Restore', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + btn.dataset.id
            }).then(() => location.reload());
        }
    });

    document.querySelectorAll('.delete-forever').forEach(btn => btn.onclick = e => {
        e.stopPropagation();
        if (confirm('Xóa vĩnh viễn file này? Không thể khôi phục!')) {
            fetch('/Drive/DeleteForever', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + btn.dataset.id
            }).then(() => location.reload());
        }
    });
</script>
