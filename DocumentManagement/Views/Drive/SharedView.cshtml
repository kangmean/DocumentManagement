@model DocumentManagement.Models.SharedLink

@{
    ViewBag.Title = "Chia sẻ file";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var token = ViewContext.RouteData.Values["token"] ?? Request.QueryString["token"] ?? ViewBag.Token;
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card text-center">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="fas fa-download"></i> Tải file</h5>
            </div>
            <div class="card-body">
                <i class="fas fa-file fa-4x mb-3 text-primary"></i>
                <h4>@Model.FileName</h4>
                <p class="text-muted">Kích thước: @(Model.FileSize / 1024) KB</p>
                <!-- THÊM FORM ĐỂ GỬI MẬT KHẨU -->
                <form method="post" action="@Url.Action("DownloadShared", "Drive")">
                    <input type="hidden" name="token" value="@token" />
                    <input type="hidden" name="password" value="@ViewBag.Password" />
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fas fa-download"></i> Tải xuống
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>