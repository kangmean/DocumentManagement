            <div class="px-8 py-6 bg-surface-container-low/30 border-t border-outline-variant/10 flex items-center justify-between">
                <p class="text-on-surface-variant text-xs font-medium">Showing <span class="text-on-surface">1-4</span> of <span class="text-on-surface">1,284</span> users</p>
                <div class="flex items-center gap-2">
                    <button class="h-9 w-9 flex items-center justify-center rounded-lg border border-outline-variant/30 text-outline hover:bg-surface-container hover:text-on-surface transition-colors disabled:opacity-30" disabled="">
                        <span class="material-symbols-outlined">chevron_left</span>
