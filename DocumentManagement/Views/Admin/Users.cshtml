                    <button class="h-9 w-9 flex items-center justify-center rounded-lg bg-primary text-on-primary font-bold text-sm">1</button>
                    <button class="h-9 w-9 flex items-center justify-center rounded-lg text-on-surface-variant font-medium text-sm hover:bg-surface-container transition-colors">2</button>
                    <button class="h-9 w-9 flex items-center justify-center rounded-lg text-on-surface-variant font-medium text-sm hover:bg-surface-container transition-colors">3</button>
