@model List<DocumentManagement.Models.User>

@{
    ViewBag.Title = "Quản lý người dùng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .user-blocked {
        background-color: #fff3f3;
        opacity: 0.7;
    }

    .badge-blocked {
        background-color: #dc3545;
        color: white;
        padding: 3px 8px;
        border-radius: 20px;
        font-size: 11px;
    }

    .badge-active {
        background-color: #28a745;
        color: white;
        padding: 3px 8px;
        border-radius: 20px;
        font-size: 11px;
    }
</style>

<div class="card">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="fas fa-users"></i> Quản lý người dùng</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên đăng nhập</th>
                        <th>Họ tên</th>
                        <th>Email</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th>Dung lượng đã dùng</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr id="user-@user.ID" class="@(user.IsBlocked ? "user-blocked" : "")">
                            <td>@user.ID</td>
                            <td>@user.Username</td>
                            <td>@(user.FullName ?? "-")</td>
                            <td>@(user.Email ?? "-")</td>
                            <td>
                                @if (user.IsBlocked)
                                {
                                    <span class="badge-blocked"><i class="fas fa-ban"></i> Đã khóa</span>
                                }
                                else
                                {
                                    <span class="badge-active"><i class="fas fa-check-circle"></i> Hoạt động</span>
                                }
                            </td>
                            <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>@(user.UsedStorage / (1024 * 1024)) MB / @(user.TotalStorage) MB</td>
                            <td>
                                <button class="btn btn-sm @(user.IsBlocked ? "btn-success" : "btn-warning") toggle-block"
                                        data-id="@user.ID"
                                        data-name="@user.Username">
                                    <i class="fas @(user.IsBlocked ? "fa-unlock-alt" : "fa-lock")"></i>
                                    @(user.IsBlocked ? "Mở khóa" : "Khóa")
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var toggleButtons = document.querySelectorAll('.toggle-block');

        toggleButtons.forEach(function(button) {
            button.addEventListener('click', function(e) {
                e.preventDefault();
                var userId = this.getAttribute('data-id');
                var userName = this.getAttribute('data-name');
                var isBlocking = this.innerHTML.includes('Khóa');
                var action = isBlocking ? 'khóa' : 'mở khóa';

                if (confirm(`Bạn có chắc muốn ${action} tài khoản "${userName}"?`)) {
                    var xhr = new XMLHttpRequest();
                    xhr.open('POST', '/Admin/ToggleBlock', true);
                    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');

                    xhr.onload = function() {
                        if (xhr.status === 200) {
                            var data = JSON.parse(xhr.responseText);
                            if (data.success) {
                                location.reload();
                            } else {
                                alert('Lỗi: ' + data.message);
                            }
                        }
                    };

                    xhr.send('userId=' + userId);
                }
            });
        });
    });
</script>