                    </div>
                    <span class="material-symbols-outlined absolute -right-8 -bottom-8 text-white/20 text-[160px] select-none">groups</span>
                </div>
            </div>
            <div class="col-span-12 md:col-span-4 flex flex-col gap-4">
                <div class="flex-1 bg-white p-6 rounded-2xl flex items-center justify-between">
                    <div>
                        <p class="text-gray-500 text-xs uppercase tracking-widest mb-1">New Requests</p>
                        <p class="text-2xl font-bold text-gray-800">24</p>
                    </div>
                    <div class="h-12 w-12 rounded-full bg-[#00BCD4]/30 flex items-center justify-center">
                        <span class="material-symbols-outlined text-[#006876]">person_add</span>
                    </div>
                </div>
                <div class="flex-1 bg-white p-6 rounded-2xl flex items-center justify-between">
                    <div>
                        <p class="text-gray-500 text-xs uppercase tracking-widest mb-1">Pending Sync</p>
                        <p class="text-2xl font-bold text-gray-800">12</p>
                    </div>
                    <div class="h-12 w-12 rounded-full bg-[#FFB77B]/30 flex items-center justify-center">
                        <span class="material-symbols-outlined text-[#8F4E00]">sync</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Table Filters & Actions -->
        <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 mb-6">
            <div class="flex items-center gap-3">
                <div class="relative">
                    <select class="appearance-none bg-gray-50 border-none rounded-xl py-2 pl-4 pr-10 text-sm font-semibold text-gray-700 focus:ring-2 focus:ring-[#00BCD4]/40 cursor-pointer">
                        <option>All Roles</option>
                        <option>Admin</option>
                        <option>User</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-xs pointer-events-none">expand_more</span>
                </div>
                <div class="relative">
                    <select class="appearance-none bg-gray-50 border-none rounded-xl py-2 pl-4 pr-10 text-sm font-semibold text-gray-700 focus:ring-2 focus:ring-[#00BCD4]/40 cursor-pointer">
                        <option>Status: All</option>
                        <option>Active</option>
                        <option>Blocked</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-xs pointer-events-none">expand_more</span>
                </div>
            </div>
            <button class="bg-[#00BCD4] hover:bg-[#0097A7] text-white px-6 py-2.5 rounded-xl font-bold flex items-center gap-2 transition-all shadow-lg shadow-cyan-500/20">
                <span class="material-symbols-outlined text-lg">person_add</span>
                Add New User
            </button>
        </div>

        <!-- Data Table -->
        <div class="bg-white rounded-3xl overflow-hidden shadow-md">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50/50">
                        <th class="px-8 py-5 text-xs font-bold uppercase tracking-widest text-gray-500">User Entity</th>
                        <th class="px-8 py-5 text-xs font-bold uppercase tracking-widest text-gray-500">Role</th>
                        <th class="px-8 py-5 text-xs font-bold uppercase tracking-widest text-gray-500">Status</th>
