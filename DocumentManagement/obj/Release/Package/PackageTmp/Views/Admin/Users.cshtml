@model List<DocumentManagement.Models.User>

@{
    ViewBag.Title = "Quản lý người dùng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .admin-layout {
        display: flex;
        gap: 24px;
        align-items: flex-start;
    }

    .admin-sidebar {
        width: 280px;
        flex-shrink: 0;
        background: white;
        border-radius: 20px;
        padding: 20px;
        border: 1px solid #E0E0E0;
        position: sticky;
        top: 100px;
        align-self: flex-start;
    }

        .admin-sidebar .menu-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: 12px;
            color: #666;
            transition: all 0.2s;
            cursor: pointer;
            margin-bottom: 4px;
        }

            .admin-sidebar .menu-item i {
                width: 24px;
                font-size: 18px;
            }

            .admin-sidebar .menu-item:hover {
                background: #F5F5F5;
                color: #00BCD4;
            }

            .admin-sidebar .menu-item.active {
                background: #00BCD4;
                color: white;
            }

    .admin-content {
        flex: 1;
    }

    .page-header {
        margin-bottom: 24px;
    }

        .page-header h2 {
            font-size: 24px;
            margin-bottom: 8px;
        }

    .stats-row {
        display: flex;
        gap: 16px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .stat-badge {
        background: white;
        border-radius: 16px;
        padding: 12px 24px;
        border: 1px solid #E0E0E0;
    }

        .stat-badge .number {
            font-size: 24px;
            font-weight: 700;
            color: #00BCD4;
        }

        .stat-badge .label {
            font-size: 13px;
            color: #666;
        }

    .search-bar {
        display: flex;
        gap: 12px;
        margin-bottom: 24px;
        align-items: center;
        justify-content: flex-start;
    }

        .search-bar input {
            width: 300px;
            padding: 10px 16px;
            border: 1px solid #E0E0E0;
            border-radius: 12px;
            font-size: 14px;
        }

            .search-bar input:focus {
                outline: none;
                border-color: #00BCD4;
            }

        .search-bar button {
            padding: 10px 20px;
            background: #00BCD4;
            color: white;
            border: none;
            border-radius: 12px;
            cursor: pointer;
        }

    .search-advanced-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: white;
        color: #666;
        border: 1px solid #E0E0E0;
        border-radius: 12px;
        cursor: pointer;
    }

        .search-advanced-btn i {
            font-size: 14px;
        }

        .search-advanced-btn:hover {
            background: #F5F5F5;
        }

    .user-table {
        background: white;
        border-radius: 20px;
        border: 1px solid #E0E0E0;
        overflow: hidden;
    }

        .user-table th, .user-table td {
            padding: 14px 16px;
            border-bottom: 1px solid #F0F0F0;
            text-align: left;
        }

        .user-table th {
            background: #F8F9FA;
            font-weight: 600;
            color: #666;
        }

        .user-table tr:hover {
            background: #F8F9FA;
        }

    .status-active {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: #198754;
    }

    .status-blocked {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: #DC3545;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: currentColor;
    }

    .btn-toggle {
        background: none;
        border: none;
        cursor: pointer;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 13px;
    }

        .btn-toggle.active {
            background: #FFEBEE;
            color: #DC3545;
        }

        .btn-toggle.blocked {
            background: #E8F5E9;
            color: #198754;
        }

    /* Modal */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

        .modal-overlay.active {
            display: flex;
        }

    .modal-container {
        background: white;
        border-radius: 20px;
        width: 400px;
        padding: 24px;
        position: relative;
    }
</style>

<div class="admin-layout">
    <!-- Sidebar -->
    <div class="admin-sidebar">
        <div class="menu-item" onclick="location.href='@Url.Action("Dashboard", "Admin")'">
            <i class="fas fa-chart-line"></i> Dashboard
        </div>
        <div class="menu-item active">
            <i class="fas fa-users"></i> Quản lý người dùng
        </div>
        <div class="menu-item" onclick="location.href='@Url.Action("Files", "Admin")'">
            <i class="fas fa-file-alt"></i> Quản lý file
        </div>
        <div class="menu-item" onclick="location.href='@Url.Action("Logs", "Admin")'">
            <i class="fas fa-history"></i> Lịch sử hoạt động
        </div>
    </div>

    <!-- Content -->
    <div class="admin-content">
        <div class="page-header">
            <h2><i class="fas fa-users"></i> Quản lý người dùng</h2>
            <p>Quản lý tài khoản và trạng thái người dùng</p>
        </div>

        <!-- Stats -->
        <div class="stats-row">
            <div class="stat-badge"><div class="number">@Model.Count</div><div class="label">Tổng người dùng</div></div>
            <div class="stat-badge"><div class="number">@(Model.Count(u => !u.IsBlocked))</div><div class="label">Đang hoạt động</div></div>
            <div class="stat-badge"><div class="number">@(Model.Count(u => u.IsBlocked))</div><div class="label">Đã khóa</div></div>
        </div>

        <!-- Search -->
        <!-- Search -->
        <div class="search-bar">
            <div style="display: flex; gap: 0; align-items: center;">
                <input type="text" id="searchInput" placeholder="🔍 Tìm kiếm theo tên, email..."
                       style="width: 300px; padding: 10px 16px; border: 1px solid #E0E0E0; border-radius: 12px 0 0 12px; font-size: 14px; outline: none;">
                <button onclick="searchUsers()"
                        style="padding: 10px 20px; background: #00BCD4; color: white; border: none; border-radius: 0; cursor: pointer;">
                    <i class="fas fa-search"></i> Tìm kiếm
                </button>
                <button class="search-advanced-btn" id="adminAdvSearchBtn"
                        style="padding: 10px 20px; background: white; color: #666; border: 1px solid #E0E0E0; border-left: none; border-radius: 0 12px 12px 0; cursor: pointer; display: inline-flex; align-items: center; gap: 8px;">
                    <i class="fas fa-sliders-h"></i> Tìm kiếm nâng cao
                </button>
            </div>
        </div>

        <!-- User Table -->
        <div class="user-table">
            <table style="width: 100%;">
                <thead>
                    <tr><th>ID</th><th>Người dùng</th><th>Email</th><th>Trạng thái</th><th>Ngày tham gia</th><th>Dung lượng</th><th>Thao tác</th>
                </thead>
                <tbody id="userTableBody">
                    @foreach (var user in Model)
                    {
                        <tr class="user-row" data-name="@user.Username.ToLower()" data-fullname="@(user.FullName?.ToLower() ?? "")" data-email="@(user.Email?.ToLower() ?? "")">
                            <td>@user.ID</td>
                            <td><strong>@user.Username</strong><br><span style="font-size:12px;color:#666;">@user.FullName</span></td>
                            <td>@(user.Email ?? "-")</td>
                            <td>
                                @if (user.IsBlocked)
                                {
                                    <span class="status-blocked"><span class="status-dot"></span> Đã khóa</span>
                                }
                                else
                                {
                                    <span class="status-active"><span class="status-dot"></span> Hoạt động</span>
                                }
                            </td>
                            <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>@(user.UsedStorage / 1024) MB / @user.TotalStorage MB</td>
                            <td>
                                <button class="btn-toggle @(user.IsBlocked ? "blocked" : "active") toggle-block"
                                        data-id="@user.ID" data-name="@user.Username"
                                        data-status="@(user.IsBlocked ? "unblock" : "block")">
                                    <i class="fas @(user.IsBlocked ? "fa-unlock-alt" : "fa-lock")"></i>
                                    @(user.IsBlocked ? "Mở khóa" : "Khóa")
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal tìm kiếm nâng cao cho Admin -->
<div id="adminAdvSearchModal" class="modal-overlay">
    <div class="modal-container">
        <h3 style="margin-bottom: 20px;">Tìm kiếm nâng cao</h3>
        <div style="margin-bottom: 15px;"><label>Tên đăng nhập</label><input type="text" id="advUsername" style="width:100%; padding:8px; border:1px solid #ddd; border-radius:8px;"></div>
        <div style="margin-bottom: 15px;"><label>Họ tên</label><input type="text" id="advFullname" style="width:100%; padding:8px; border:1px solid #ddd; border-radius:8px;"></div>
        <div style="margin-bottom: 15px;"><label>Email</label><input type="text" id="advEmail" style="width:100%; padding:8px; border:1px solid #ddd; border-radius:8px;"></div>
        <div style="margin-bottom: 20px;">
            <label>Trạng thái</label>
            <select id="advStatus" style="width:100%; padding:8px; border:1px solid #ddd; border-radius:8px;">
                <option value="">Tất cả</option>
                <option value="active">Hoạt động</option>
                <option value="blocked">Đã khóa</option>
            </select>
        </div>
        <div style="display: flex; gap: 10px; justify-content: flex-end;">
            <button id="closeAdminAdvSearch" style="padding:8px 16px; background:#F5F5F5; border:none; border-radius:8px;">Hủy</button>
            <button id="submitAdminAdvSearch" style="padding:8px 16px; background:#00BCD4; color:white; border:none; border-radius:8px;">Tìm kiếm</button>
        </div>
    </div>
</div>

<script>
    // ==================== TOGGLE BLOCK USER ====================
    document.querySelectorAll('.toggle-block').forEach(btn => {
        btn.addEventListener('click', function (e) {
            e.preventDefault();
            var userId = this.getAttribute('data-id');
            var userName = this.getAttribute('data-name');
            var action = this.getAttribute('data-status') === 'block' ? 'khóa' : 'mở khóa';

            if (confirm(`Bạn có chắc muốn ${action} tài khoản "${userName}"?`)) {
                var xhr = new XMLHttpRequest();
                xhr.open('POST', '/Admin/ToggleBlock', true);
                xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
                xhr.onload = function () {
                    if (xhr.status === 200) {
                        var data = JSON.parse(xhr.responseText);
                        if (data.success) {
                            location.reload();
                        } else {
                            alert('Lỗi: ' + data.message);
                        }
                    } else {
                        alert('Lỗi kết nối server');
                    }
                };
                xhr.send('userId=' + userId);
            }
        });
    });

    // ==================== TÌM KIẾM CƠ BẢN ====================
    function searchUsers() {
        var keyword = document.getElementById('searchInput').value.toLowerCase();
        var rows = document.querySelectorAll('.user-row');

        rows.forEach(row => {
            var name = row.getAttribute('data-name') || '';
            var fullname = row.getAttribute('data-fullname') || '';
            var email = row.getAttribute('data-email') || '';

            if (name.includes(keyword) || fullname.includes(keyword) || email.includes(keyword) || keyword === '') {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }

    // Enter để tìm kiếm
    var searchInput = document.getElementById('searchInput');
    if (searchInput) {
        searchInput.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                searchUsers();
            }
        });
    }

    // ==================== TÌM KIẾM NÂNG CAO (ADMIN USERS) ====================
    var adminModal = document.getElementById('adminAdvSearchModal');
    var adminAdvBtn = document.getElementById('adminAdvSearchBtn');
    var adminCloseBtn = document.getElementById('closeAdminAdvSearch');
    var adminSubmitBtn = document.getElementById('submitAdminAdvSearch');

    // Mở modal
    if (adminAdvBtn) {
        adminAdvBtn.onclick = function (e) {
            e.preventDefault();
            // Reset form
            var advUsername = document.getElementById('advUsername');
            var advFullname = document.getElementById('advFullname');
            var advEmail = document.getElementById('advEmail');
            var advStatus = document.getElementById('advStatus');

            if (advUsername) advUsername.value = '';
            if (advFullname) advFullname.value = '';
            if (advEmail) advEmail.value = '';
            if (advStatus) advStatus.value = '';

            if (adminModal) adminModal.style.display = 'flex';
        };
    }

    // Đóng modal bằng nút X
    if (adminCloseBtn) {
        adminCloseBtn.onclick = function () {
            if (adminModal) adminModal.style.display = 'none';
        };
    }

    // Đóng modal khi click ra ngoài
    if (adminModal) {
        adminModal.onclick = function (e) {
            if (e.target === adminModal) {
                adminModal.style.display = 'none';
            }
        };
    }

    // Submit tìm kiếm nâng cao
    if (adminSubmitBtn) {
        adminSubmitBtn.onclick = function () {
            var username = document.getElementById('advUsername').value.toLowerCase();
            var fullname = document.getElementById('advFullname').value.toLowerCase();
            var email = document.getElementById('advEmail').value.toLowerCase();
            var status = document.getElementById('advStatus').value;

            var rows = document.querySelectorAll('.user-row');

            rows.forEach(row => {
                var rowUsername = row.getAttribute('data-name') || '';
                var rowFullname = row.getAttribute('data-fullname') || '';
                var rowEmail = row.getAttribute('data-email') || '';

                // Xác định trạng thái của dòng
                var statusSpan = row.querySelector('.status-active, .status-blocked');
                var rowStatus = 'active';
                if (statusSpan && statusSpan.innerText.includes('Đã khóa')) {
                    rowStatus = 'blocked';
                }

                var match = true;

                if (username && !rowUsername.includes(username)) match = false;
                if (fullname && !rowFullname.includes(fullname)) match = false;
                if (email && !rowEmail.includes(email)) match = false;
                if (status && rowStatus !== status) match = false;

                row.style.display = match ? '' : 'none';
            });

            // Đóng modal sau khi tìm
            if (adminModal) adminModal.style.display = 'none';
        };
    }
</script>