@model List<DocumentManagement.Models.FileModel>

@{
    ViewBag.Title = "Quản lý file";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .admin-layout {
        display: flex;
        gap: 24px;
        align-items: flex-start;
    }

    .admin-sidebar {
        width: 280px;
        flex-shrink: 0;
        background: white;
        border-radius: 20px;
        padding: 20px;
        border: 1px solid #E0E0E0;
        position: sticky;
        top: 100px;
        align-self: flex-start;
    }

        .admin-sidebar .menu-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: 12px;
            color: #666;
            transition: all 0.2s;
            cursor: pointer;
            margin-bottom: 4px;
        }

            .admin-sidebar .menu-item i {
                width: 24px;
                font-size: 18px;
            }

            .admin-sidebar .menu-item:hover {
                background: #F5F5F5;
                color: #00BCD4;
            }

            .admin-sidebar .menu-item.active {
                background: #00BCD4;
                color: white;
            }

    .admin-content {
        flex: 1;
    }

    .page-header {
        margin-bottom: 24px;
    }

        .page-header h2 {
            font-size: 24px;
            margin-bottom: 8px;
        }

    .stats-row {
        display: flex;
        gap: 16px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .stat-badge {
        background: white;
        border-radius: 16px;
        padding: 12px 24px;
        border: 1px solid #E0E0E0;
    }

        .stat-badge .number {
            font-size: 24px;
            font-weight: 700;
            color: #00BCD4;
        }

        .stat-badge .label {
            font-size: 13px;
            color: #666;
        }

    .search-bar {
        display: flex;
        gap: 12px;
        margin-bottom: 24px;
        align-items: center;
        justify-content: flex-start;
    }

        .search-bar input {
            width: 300px;
            padding: 10px 16px;
            border: 1px solid #E0E0E0;
            border-radius: 12px;
            font-size: 14px;
        }

            .search-bar input:focus {
                outline: none;
                border-color: #00BCD4;
            }

        .search-bar button {
            padding: 10px 20px;
            background: #00BCD4;
            color: white;
            border: none;
            border-radius: 12px;
            cursor: pointer;
        }

    .search-advanced-btn {
        padding: 10px 20px;
        background: white;
        color: #666;
        border: 1px solid #E0E0E0;
        border-radius: 12px;
        cursor: pointer;
    }

        .search-advanced-btn:hover {
            background: #F5F5F5;
        }

    .file-table {
        background: white;
        border-radius: 20px;
        border: 1px solid #E0E0E0;
        overflow: hidden;
    }

        .file-table th, .file-table td {
            padding: 14px 16px;
            border-bottom: 1px solid #F0F0F0;
            text-align: left;
        }

        .file-table th {
            background: #F8F9FA;
            font-weight: 600;
            color: #666;
        }

        .file-table tr:hover {
            background: #F8F9FA;
        }

    .file-icon {
        font-size: 24px;
        margin-right: 12px;
        vertical-align: middle;
    }

    .badge-type {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 500;
    }

    .badge-pdf {
        background: #FFEBEE;
        color: #DC3545;
    }

    .badge-word {
        background: #E3F2FD;
        color: #0D6EFD;
    }

    .badge-excel {
        background: #E8F5E9;
        color: #198754;
    }

    .badge-image {
        background: #FFF3E0;
        color: #FF9800;
    }

    .badge-other {
        background: #F5F5F5;
        color: #666;
    }

    .btn-delete {
        background: none;
        border: none;
        cursor: pointer;
        padding: 8px 12px;
        border-radius: 8px;
        color: #DC3545;
        transition: all 0.2s;
    }

        .btn-delete:hover {
            background: #FFEBEE;
        }

    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

        .modal-overlay.active {
            display: flex;
        }

    .modal-container {
        background: white;
        border-radius: 20px;
        width: 400px;
        padding: 24px;
        position: relative;
    }

    .search-advanced-btn {
        display: inline-flex !important;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: white !important;
        color: #666 !important;
        border: 1px solid #E0E0E0 !important;
        border-radius: 12px !important;
        cursor: pointer;
        font-size: 14px;
    }

        .search-advanced-btn i {
            font-size: 14px;
            margin-right: 4px;
        }

        .search-advanced-btn:hover {
            background: #F5F5F5 !important;
        }
</style>

<div class="admin-layout">
    <div class="admin-sidebar">
        <div class="menu-item" onclick="location.href='@Url.Action("Dashboard", "Admin")'"><i class="fas fa-chart-line"></i> Dashboard</div>
        <div class="menu-item" onclick="location.href='@Url.Action("Users", "Admin")'"><i class="fas fa-users"></i> Quản lý người dùng</div>
        <div class="menu-item active"><i class="fas fa-file-alt"></i> Quản lý file</div>
        <div class="menu-item" onclick="location.href='@Url.Action("Logs", "Admin")'"><i class="fas fa-history"></i> Lịch sử hoạt động</div>
    </div>

    <div class="admin-content">
        <div class="page-header">
            <h2><i class="fas fa-file-alt"></i> Quản lý file</h2>
            <p>Quản lý tất cả file trong hệ thống</p>
        </div>

        <div class="stats-row">
            <div class="stat-badge"><div class="number">@Model.Count</div><div class="label">Tổng số file</div></div>
            <div class="stat-badge"><div class="number">@(Model.Sum(f => f.FileSize) / (1024 * 1024)) MB</div><div class="label">Tổng dung lượng</div></div>
        </div>

        <div class="search-bar">
            <div style="display: flex; gap: 0; align-items: center;">
                <input type="text" id="searchInput" placeholder="🔍 Tìm kiếm theo tên file hoặc người dùng..."
                       style="width: 300px; padding: 10px 16px; border: 1px solid #E0E0E0; border-radius: 12px 0 0 12px; font-size: 14px; outline: none;">
                <button onclick="searchFiles()"
                        style="padding: 10px 20px; background: #00BCD4; color: white; border: none; border-radius: 0; cursor: pointer;">
                    <i class="fas fa-search"></i> Tìm kiếm
                </button>
                <button id="adminFileAdvSearchBtn"
                        style="display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; background: white; color: #666; border: 1px solid #E0E0E0; border-left: none; border-radius: 0 12px 12px 0; cursor: pointer;">
                    <i class="fas fa-sliders-h"></i> Tìm kiếm nâng cao
                </button>
            </div>
        </div>

        <div class="file-table">
            <table style="width: 100%;">
                <thead><tr><th>ID</th><th>Tên file</th><th>Kích thước</th><th>Loại</th><th>Người dùng</th><th>Ngày upload</th><th>Thao tác</th></tr></thead>
                <tbody id="fileTableBody">
                    @foreach (var file in Model)
                    {
                        string badgeClass = "badge-other";
                        if (file.FileType == "pdf") { badgeClass = "badge-pdf"; }
                        else if (file.FileType == "docx" || file.FileType == "doc") { badgeClass = "badge-word"; }
                        else if (file.FileType == "xlsx" || file.FileType == "xls") { badgeClass = "badge-excel"; }
                        else if (file.FileType == "jpg" || file.FileType == "png") { badgeClass = "badge-image"; }

                        <tr class="file-row" data-name="@file.FileName.ToLower()" data-userid="@file.UserID">
                            <td>@file.ID</td>
                            <td><i class="fas @(file.FileType == "pdf" ? "fa-file-pdf" : file.FileType == "docx" ? "fa-file-word" : file.FileType == "xlsx" ? "fa-file-excel" : file.FileType == "jpg" || file.FileType == "png" ? "fa-file-image" : "fa-file") file-icon" style="color:@(file.FileType == "pdf" ? "#DC3545" : file.FileType == "docx" ? "#0D6EFD" : file.FileType == "xlsx" ? "#198754" : file.FileType == "jpg" || file.FileType == "png" ? "#FF9800" : "#6C757D")"></i> @file.FileName</td>
                            <td>@file.FormattedSize</td>
                            <td><span class="badge-type @badgeClass">@file.FileType.ToUpper()</span></td>
                            <td>User ID: @file.UserID</td>
                            <td>@file.UploadedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><button class="btn-delete delete-file" data-id="@file.ID" data-name="@file.FileName"><i class="fas fa-trash"></i> Xóa</button></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal tìm kiếm nâng cao cho File -->
<div id="adminFileAdvSearchModal" class="modal-overlay">
    <div class="modal-container">
        <h3 style="margin-bottom: 20px;">Tìm kiếm nâng cao</h3>
        <div style="margin-bottom: 15px;"><label>Tên file</label><input type="text" id="advFileName" style="width:100%; padding:8px; border:1px solid #ddd; border-radius:8px;"></div>
        <div style="margin-bottom: 15px;">
            <label>Loại file</label>
            <select id="advFileType" style="width:100%; padding:8px; border:1px solid #ddd; border-radius:8px;">
                <option value="">Tất cả</option>
                <option value="pdf">PDF</option>
                <option value="docx">Word</option>
                <option value="xlsx">Excel</option>
                <option value="jpg">Hình ảnh</option>
            </select>
        </div>
        <div style="margin-bottom: 15px;">
            <label>Kích thước</label>
            <select id="advSize" style="width:100%; padding:8px; border:1px solid #ddd; border-radius:8px;">
                <option value="">Không giới hạn</option>
                <option value="lt1">&lt; 1 MB</option>
                <option value="lt5">&lt; 5 MB</option>
                <option value="gt5">&gt; 5 MB</option>
            </select>
        </div>
        <div style="margin-bottom: 20px;"><label>Người dùng ID</label>
                                          <input type="number" id="advUserId" min="1" step="1"
                                                 onkeydown="return event.key !== '-'"
                                                 oninput="this.value = Math.abs(parseInt(this.value)) || ''"
                                                 style="width:100%; padding:8px; border:1px solid #ddd; border-radius:8px;"
                                                 placeholder="Nhập ID người dùng"></div>
        <div style="display: flex; gap: 10px; justify-content: flex-end;">
            <button id="closeAdminFileAdvSearch" style="padding:8px 16px; background:#F5F5F5; border:none; border-radius:8px;">Hủy</button>
            <button id="submitAdminFileAdvSearch" style="padding:8px 16px; background:#00BCD4; color:white; border:none; border-radius:8px;">Tìm kiếm</button>
        </div>
    </div>
</div>

<script>
    // ==================== XÓA FILE ====================
    document.querySelectorAll('.delete-file').forEach(btn => {
        btn.addEventListener('click', function (e) {
            e.preventDefault();
            var fileId = this.getAttribute('data-id');
            var fileName = this.getAttribute('data-name');

            if (confirm(`Bạn có chắc muốn xóa file "${fileName}"? Hành động này không thể hoàn tác!`)) {
                var xhr = new XMLHttpRequest();
                xhr.open('POST', '/Admin/DeleteFile', true);
                xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
                xhr.onload = function () {
                    if (xhr.status === 200) {
                        var data = JSON.parse(xhr.responseText);
                        if (data.success) {
                            location.reload();
                        } else {
                            alert('Lỗi: ' + data.message);
                        }
                    } else {
                        alert('Lỗi kết nối server');
                    }
                };
                xhr.send('fileId=' + fileId);
            }
        });
    });

    // ==================== TÌM KIẾM CƠ BẢN ====================
    function searchFiles() {
        var keyword = document.getElementById('searchInput').value.toLowerCase();
        var rows = document.querySelectorAll('.file-row');

        rows.forEach(row => {
            var name = row.getAttribute('data-name') || '';
            if (name.includes(keyword) || keyword === '') {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }

    // Enter để tìm kiếm
    var searchInput = document.getElementById('searchInput');
    if (searchInput) {
        searchInput.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                searchFiles();
            }
        });
    }

    // ==================== TÌM KIẾM NÂNG CAO (ADMIN FILES) ====================
    var adminFileModal = document.getElementById('adminFileAdvSearchModal');
    var adminFileAdvBtn = document.getElementById('adminFileAdvSearchBtn');
    var adminFileCloseBtn = document.getElementById('closeAdminFileAdvSearch');
    var adminFileSubmitBtn = document.getElementById('submitAdminFileAdvSearch');

    // Mở modal
    if (adminFileAdvBtn) {
        adminFileAdvBtn.onclick = function (e) {
            e.preventDefault();
            // Reset form
            var advFileName = document.getElementById('advFileName');
            var advFileType = document.getElementById('advFileType');
            var advSize = document.getElementById('advSize');
            var advUserId = document.getElementById('advUserId');

            if (advFileName) advFileName.value = '';
            if (advFileType) advFileType.value = '';
            if (advSize) advSize.value = '';
            if (advUserId) advUserId.value = '';  // Đặt về chuỗi rỗng, không phải null hay undefined

            if (adminFileModal) adminFileModal.style.display = 'flex';
        };
    }

    // Đóng modal bằng nút X
    if (adminFileCloseBtn) {
        adminFileCloseBtn.onclick = function () {
            if (adminFileModal) adminFileModal.style.display = 'none';
        };
    }

    // Đóng modal khi click ra ngoài
    if (adminFileModal) {
        adminFileModal.onclick = function (e) {
            if (e.target === adminFileModal) {
                adminFileModal.style.display = 'none';
            }
        };
    }

    // Submit tìm kiếm nâng cao
    if (adminFileSubmitBtn) {
        adminFileSubmitBtn.onclick = function () {
            var fileName = document.getElementById('advFileName').value.toLowerCase();
            var fileType = document.getElementById('advFileType').value;
            var size = document.getElementById('advSize').value;
            var userId = document.getElementById('advUserId').value;

            var rows = document.querySelectorAll('.file-row');

            rows.forEach(row => {
                var rowName = row.getAttribute('data-name') || '';
                var rowType = row.querySelector('.badge-type')?.innerText.toLowerCase() || '';
                var rowSizeText = row.cells[2]?.innerText || '';
                var rowUserId = row.getAttribute('data-userid') || '';

                // Chuyển kích thước về MB
                var sizeMB = 0;
                if (rowSizeText.includes('KB')) {
                    sizeMB = parseFloat(rowSizeText) / 1024;
                } else if (rowSizeText.includes('MB')) {
                    sizeMB = parseFloat(rowSizeText);
                } else if (rowSizeText.includes('GB')) {
                    sizeMB = parseFloat(rowSizeText) * 1024;
                }

                var match = true;

                // Lọc theo tên file
                if (fileName && !rowName.includes(fileName)) match = false;

                // Lọc theo loại file
                if (fileType && !rowType.includes(fileType)) match = false;

                // Lọc theo kích thước
                if (size) {
                    if (size === 'lt1' && sizeMB >= 1) match = false;
                    if (size === 'lt5' && sizeMB >= 5) match = false;
                    if (size === 'gt5' && sizeMB <= 5) match = false;
                }

                // Lọc theo user ID
                if (userId && rowUserId !== userId) match = false;

                row.style.display = match ? '' : 'none';
            });

            // Đóng modal sau khi tìm
            if (adminFileModal) adminFileModal.style.display = 'none';
        };
    }
</script>