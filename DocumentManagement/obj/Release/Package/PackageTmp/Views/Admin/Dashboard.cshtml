@model DocumentManagement.Models.AdminDashboardViewModel

@{
    ViewBag.Title = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Dashboard Layout */
    .dashboard-layout {
        display: flex;
        gap: 24px;
        align-items: flex-start;
    }

    /* Sidebar Admin */
    .admin-sidebar {
        width: 280px;
        flex-shrink: 0;
        background: white;
        border-radius: 20px;
        padding: 20px;
        border: 1px solid #E0E0E0;
        position: sticky;
        top: 100px;
        align-self: flex-start;
    }

        .admin-sidebar .menu-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: 12px;
            color: #666;
            transition: all 0.2s;
            cursor: pointer;
            margin-bottom: 4px;
        }

            .admin-sidebar .menu-item i {
                width: 24px;
                font-size: 18px;
            }

            .admin-sidebar .menu-item:hover {
                background: #F5F5F5;
                color: #00BCD4;
            }

            .admin-sidebar .menu-item.active {
                background: #00BCD4;
                color: white;
            }

    /* Dashboard Content */
    .dashboard-content {
        flex: 1;
    }

    /* Stats Cards */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 20px;
        padding: 20px;
        border: 1px solid #E0E0E0;
        transition: all 0.2s;
        position: relative;
        overflow: hidden;
    }

        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.05);
            border-color: #00BCD4;
        }

        .stat-card .stat-icon {
            position: absolute;
            right: 20px;
            top: 20px;
            font-size: 48px;
            opacity: 0.1;
        }

        .stat-card .stat-value {
            font-size: 32px;
            font-weight: 700;
            color: #212121;
            margin-bottom: 4px;
        }

        .stat-card .stat-label {
            font-size: 14px;
            color: #666;
        }

    /* Section Cards */
    .section-card {
        background: white;
        border-radius: 20px;
        padding: 20px;
        border: 1px solid #E0E0E0;
        margin-bottom: 24px;
    }

    .section-title {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 16px;
        padding-bottom: 12px;
        border-bottom: 2px solid #00BCD4;
        display: inline-block;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

        .data-table th {
            text-align: left;
            padding: 12px 8px;
            color: #666;
            font-weight: 600;
            font-size: 13px;
            border-bottom: 1px solid #E0E0E0;
        }

        .data-table td {
            padding: 12px 8px;
            border-bottom: 1px solid #F0F0F0;
            color: #333;
        }

        .data-table tr:hover {
            background: #F8F9FA;
        }

    .badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 500;
    }

    .badge-pdf {
        background: #FFEBEE;
        color: #DC3545;
    }

    .badge-word {
        background: #E3F2FD;
        color: #0D6EFD;
    }

    .badge-excel {
        background: #E8F5E9;
        color: #198754;
    }

    .badge-other {
        background: #F5F5F5;
        color: #666;
    }

    .rank-1 {
        background: #FFD700;
        color: #333;
    }

    .rank-2 {
        background: #C0C0C0;
        color: #333;
    }

    .rank-3 {
        background: #CD7F32;
        color: #333;
    }
</style>

<div class="dashboard-layout">
    <!-- Sidebar Admin -->
    <div class="admin-sidebar">
        <div class="menu-item active">
            <i class="fas fa-chart-line"></i> Dashboard
        </div>
        <div class="menu-item" onclick="location.href='@Url.Action("Users", "Admin")'">
            <i class="fas fa-users"></i> Quản lý người dùng
        </div>
        <div class="menu-item" onclick="location.href='@Url.Action("Files", "Admin")'">
            <i class="fas fa-file-alt"></i> Quản lý file
        </div>
        <div class="menu-item" onclick="location.href='@Url.Action("Logs", "Admin")'">
            <i class="fas fa-history"></i> Lịch sử hoạt động
        </div>
    </div>

    <!-- Dashboard Content -->
    <div class="dashboard-content">
        <h2 style="margin-bottom: 24px; font-size: 24px;">Admin Dashboard</h2>

        <!-- Stats Cards -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-users"></i></div>
                <div class="stat-value">@Model.TotalUsers</div>
                <div class="stat-label">Người dùng</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-file"></i></div>
                <div class="stat-value">@Model.TotalFiles</div>
                <div class="stat-label">Tổng file</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-database"></i></div>
                <div class="stat-value">@(Model.TotalStorage / (1024 * 1024)) MB</div>
                <div class="stat-label">Dung lượng đã dùng</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-trash"></i></div>
                <div class="stat-value">@Model.TrashFiles</div>
                <div class="stat-label">File trong thùng rác</div>
            </div>
        </div>

        <!-- Top Users & Top Files -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px;">
            <!-- Top Users -->
            <div class="section-card">
                <div class="section-title">
                    <i class="fas fa-trophy" style="color: #00BCD4; margin-right: 8px;"></i>
                    Top 5 người dùng upload nhiều nhất
                </div>
                <table class="data-table">
                    <thead>
                        <tr><th>#</th><th>Tên đăng nhập</th><th>Số file</th><th>Dung lượng</th></tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.TopUsers.Count; i++)
                        {
                            var user = Model.TopUsers[i];
                            <tr>
                                <td><span class="badge rank-@(i+1)">@(i+1)</span></td>
                                <td>@user.Username</td>
                                <td>@user.FileCount</td>
                                <td>@user.FormattedSize</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Top Files -->
            <div class="section-card">
                <div class="section-title">
                    <i class="fas fa-download" style="color: #00BCD4; margin-right: 8px;"></i>
                    Top 5 file được tải nhiều nhất
                </div>
                <table class="data-table">
                    <thead>
                        <tr><th>#</th><th>Tên file</th><th>Lượt tải</th><th>Người upload</th></tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.TopFiles.Count; i++)
                        {
                            var file = Model.TopFiles[i];
                            <tr>
                                <td>@(i+1)</td>
                                <td>@file.FileName</td>
                                <td>@file.DownloadCount</td>
                                <td>@file.UploaderName</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Recent Files -->
        <div class="section-card">
            <div class="section-title">
                <i class="fas fa-clock" style="color: #00BCD4; margin-right: 8px;"></i>
                File mới upload gần đây
            </div>
            <div style="overflow-x: auto;">
                <table class="data-table">
                    <thead>
                        <tr><th>Tên file</th><th>Kích thước</th><th>Loại</th><th>Ngày upload</th><th>User ID</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var file in Model.RecentFiles)
                        {
                            <tr>
                                <td>@file.FileName</td>
                                <td>@file.FormattedSize</td>
                                <td><span class="badge @(file.FileType == "pdf" ? "badge-pdf" : file.FileType == "docx" ? "badge-word" : file.FileType == "xlsx" ? "badge-excel" : "badge-other")">@file.FileType</span></td>
                                <td>@file.UploadedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@file.UserID</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>