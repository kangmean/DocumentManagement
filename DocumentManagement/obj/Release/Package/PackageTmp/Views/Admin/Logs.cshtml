@model List<DocumentManagement.Models.ActivityLog>

@{
    ViewBag.Title = "Lịch sử hoạt động";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .admin-layout {
        display: flex;
        gap: 24px;
        align-items: flex-start;
    }

    .admin-sidebar {
        width: 280px;
        flex-shrink: 0;
        background: white;
        border-radius: 20px;
        padding: 20px;
        border: 1px solid #E0E0E0;
        position: sticky;
        top: 100px;
        align-self: flex-start;
    }

        .admin-sidebar .menu-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: 12px;
            color: #666;
            transition: all 0.2s;
            cursor: pointer;
            margin-bottom: 4px;
        }

            .admin-sidebar .menu-item i {
                width: 24px;
                font-size: 18px;
            }

            .admin-sidebar .menu-item:hover {
                background: #F5F5F5;
                color: #00BCD4;
            }

            .admin-sidebar .menu-item.active {
                background: #00BCD4;
                color: white;
            }

    .admin-content {
        flex: 1;
    }

    .page-header {
        margin-bottom: 24px;
    }

        .page-header h2 {
            font-size: 24px;
            margin-bottom: 8px;
        }

    .stats-row {
        display: flex;
        gap: 16px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .stat-badge {
        background: white;
        border-radius: 16px;
        padding: 12px 24px;
        border: 1px solid #E0E0E0;
    }

        .stat-badge .number {
            font-size: 24px;
            font-weight: 700;
            color: #00BCD4;
        }

        .stat-badge .label {
            font-size: 13px;
            color: #666;
        }

    .filter-bar {
        display: flex;
        gap: 12px;
        margin-bottom: 24px;
        align-items: center;
    }

        .filter-bar select {
            padding: 10px 16px;
            border: 1px solid #E0E0E0;
            border-radius: 12px;
            background: white;
        }

        .filter-bar button {
            padding: 10px 20px;
            background: #00BCD4;
            color: white;
            border: none;
            border-radius: 12px;
            cursor: pointer;
        }

    .logs-table {
        background: white;
        border-radius: 20px;
        border: 1px solid #E0E0E0;
        overflow-x: auto;
    }

        .logs-table table {
            width: 100%;
            border-collapse: collapse;
        }

        .logs-table th, .logs-table td {
            padding: 14px 16px;
            border-bottom: 1px solid #F0F0F0;
            text-align: left;
        }

        .logs-table th {
            background: #F8F9FA;
            font-weight: 600;
            color: #666;
        }

        .logs-table tr:hover {
            background: #F8F9FA;
        }

    .badge-action {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
    }

    .badge-upload {
        background: #E8F5E9;
        color: #198754;
    }

    .badge-download {
        background: #E3F2FD;
        color: #0D6EFD;
    }

    .badge-delete {
        background: #FFEBEE;
        color: #DC3545;
    }

    .badge-share {
        background: #FFF3E0;
        color: #FF9800;
    }

    .ip-code {
        font-family: monospace;
        background: #F5F5F5;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
    }
</style>

<div class="admin-layout">
    <div class="admin-sidebar">
        <div class="menu-item" onclick="location.href='@Url.Action("Dashboard", "Admin")'"><i class="fas fa-chart-line"></i> Dashboard</div>
        <div class="menu-item" onclick="location.href='@Url.Action("Users", "Admin")'"><i class="fas fa-users"></i> Quản lý người dùng</div>
        <div class="menu-item" onclick="location.href='@Url.Action("Files", "Admin")'"><i class="fas fa-file-alt"></i> Quản lý file</div>
        <div class="menu-item active"><i class="fas fa-history"></i> Lịch sử hoạt động</div>
    </div>

    <div class="admin-content">
        <div class="page-header">
            <h2><i class="fas fa-history"></i> Lịch sử hoạt động</h2>
            <p>Theo dõi toàn bộ hoạt động của người dùng</p>
        </div>

        <div class="stats-row">
            <div class="stat-badge"><div class="number">@Model.Count</div><div class="label">Tổng số hoạt động</div></div>
            <div class="stat-badge"><div class="number">@Model.Count(l => l.Action == "Upload")</div><div class="label">Upload</div></div>
            <div class="stat-badge"><div class="number">@Model.Count(l => l.Action == "Download")</div><div class="label">Download</div></div>
            <div class="stat-badge"><div class="number">@Model.Count(l => l.Action == "Delete")</div><div class="label">Xóa</div></div>
            <div class="stat-badge"><div class="number">@Model.Count(l => l.Action == "Share")</div><div class="label">Chia sẻ</div></div>
        </div>

        <div class="filter-bar">
            <select id="actionFilter">
                <option value="all">Tất cả hành động</option>
                <option value="Upload">📤 Upload</option>
                <option value="Download">📥 Download</option>
                <option value="Delete">🗑️ Xóa</option>
                <option value="Share">🔗 Chia sẻ</option>
            </select>
            <button onclick="filterLogs()"><i class="fas fa-filter"></i> Lọc</button>
        </div>

        <div class="logs-table">
            <table>
                <thead>
                    <tr>
                        <th>Thời gian</th>
                        <th>Người dùng</th>
                        <th>Hành động</th>
                        <th>Tên file</th>
                        <th>Kích thước</th>
                        <th>IP Address</th>
                    </tr>
                </thead>
                <tbody id="logsTableBody">
                    @foreach (var log in Model)
                    {
                        string badgeClass = "";
                        string icon = "";
                        switch (log.Action)
                        {
                            case "Upload": badgeClass = "badge-upload"; icon = "📤"; break;
                            case "Download": badgeClass = "badge-download"; icon = "📥"; break;
                            case "Delete": badgeClass = "badge-delete"; icon = "🗑️"; break;
                            case "Share": badgeClass = "badge-share"; icon = "🔗"; break;
                        }
                        <tr class="log-row" data-action="@log.Action">
                            <td style="white-space: nowrap;">@log.Time.ToString("dd/MM/yyyy HH:mm:ss")</td>
                            <td>@log.UserName</td>
                            <td><span class="badge-action @badgeClass">@icon @log.Action</span></td>
                            <td>@log.FileName</td>
                            <td>@log.FormattedSize</td>
                            <td><code class="ip-code">@log.IPAddress</code></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    function filterLogs() {
        var action = document.getElementById('actionFilter').value;
        document.querySelectorAll('.log-row').forEach(row => {
            row.style.display = (action === 'all' || row.getAttribute('data-action') === action) ? '' : 'none';
        });
    }
</script>