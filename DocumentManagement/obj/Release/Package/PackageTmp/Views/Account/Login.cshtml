@model DocumentManagement.Models.LoginModel

@{
    ViewBag.Title = "Đăng nhập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --primary: #00BCD4;
        --primary-dark: #0097A7;
        --text-dark: #212121;
        --text-light: #666666;
        --white: #FFFFFF;
        --border: #E0E0E0;
        --error: #DC3545;
        --error-bg: #FFEBEE;
    }

    .login-container {
        min-height: calc(100vh - 200px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
    }

    .login-card {
        max-width: 450px;
        width: 100%;
        background: var(--white);
        border-radius: 24px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .login-header {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        padding: 32px;
        text-align: center;
        color: white;
    }

        .login-header i {
            font-size: 48px;
            margin-bottom: 12px;
        }

        .login-header h2 {
            margin: 0;
            font-size: 24px;
            font-weight: 700;
        }

        .login-header p {
            margin: 8px 0 0;
            opacity: 0.9;
            font-size: 14px;
        }

    .login-body {
        padding: 32px;
    }

    .alert-danger {
        background: var(--error-bg);
        color: var(--error);
        padding: 12px 16px;
        border-radius: 12px;
        margin-bottom: 20px;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            color: var(--text-dark);
        }

        .form-group input {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid var(--border);
            border-radius: 12px;
            font-size: 14px;
            transition: all 0.2s;
        }

            .form-group input:focus {
                outline: none;
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(0, 188, 212, 0.1);
            }

    .btn-login {
        width: 100%;
        padding: 12px;
        background: var(--primary);
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

        .btn-login:hover {
            background: var(--primary-dark);
            transform: translateY(-1px);
        }

    .login-footer {
        padding: 20px 32px;
        text-align: center;
        border-top: 1px solid var(--border);
        background: #FAFAFA;
        font-size: 13px;
        color: var(--text-light);
    }

        .login-footer strong {
            color: var(--primary);
        }
</style>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <i class="fas fa-cloud-upload-alt"></i>
            <h2>DOCUMENT MANAGEMENT</h2>
            <p>Đăng nhập để quản lý tài liệu</p>
        </div>
        <div class="login-body">
            @using (Html.BeginForm("Login", "Account", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                if (!string.IsNullOrEmpty(ViewBag.Error))
                {
                    <div class="alert-danger">
                        <i class="fas fa-exclamation-triangle"></i> @ViewBag.Error
                    </div>
                }

                <div class="form-group">
                    @Html.LabelFor(m => m.Username, "Tên đăng nhập")
                    @Html.TextBoxFor(m => m.Username, new { @class = "form-control", placeholder = "Nhập tên đăng nhập" })
                    @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger", style = "font-size:12px; margin-top:4px; display:block;" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(m => m.Password, "Mật khẩu")
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Nhập mật khẩu" })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger", style = "font-size:12px; margin-top:4px; display:block;" })
                </div>

                <button type="submit" class="btn-login">
                    <i class="fas fa-sign-in-alt"></i> Đăng nhập
                </button>
            }
        </div>
        <div class="login-footer">
            <i class="fas fa-key"></i> Tài khoản mẫu: <strong>admin</strong>/123, <strong>user1</strong>/123
        </div>
    </div>
</div>
<div style="text-align: center; margin-top: 16px;">
    <a href="@Url.Action("Register", "Account")" style="color: #00BCD4;">Đăng ký tài khoản</a>
    <span style="margin: 0 8px;">|</span>
    <a href="@Url.Action("ForgotPassword", "Account")" style="color: #00BCD4;">Quên mật khẩu?</a>
</div>