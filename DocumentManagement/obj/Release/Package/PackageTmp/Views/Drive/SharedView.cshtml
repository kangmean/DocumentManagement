@model DocumentManagement.Models.SharedLink

@{
    ViewBag.Title = "Chia sẻ file";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var token = ViewContext.RouteData.Values["token"] ?? Request.QueryString["token"] ?? ViewBag.Token;
}

<style>
    :root {
        --primary: #00BCD4;
        --primary-dark: #0097A7;
        --text-dark: #212121;
        --text-light: #666666;
        --white: #FFFFFF;
        --border: #E0E0E0;
    }

    .share-container {
        max-width: 500px;
        margin: 80px auto;
    }

    .share-card {
        background: var(--white);
        border-radius: 24px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        text-align: center;
    }

    .share-header {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        padding: 24px;
        color: white;
    }

        .share-header h3 {
            margin: 0;
            font-size: 20px;
            font-weight: 600;
        }

    .share-body {
        padding: 32px;
    }

    .file-icon {
        font-size: 64px;
        color: var(--primary);
        margin-bottom: 20px;
    }

    .file-name {
        font-size: 18px;
        font-weight: 600;
        color: var(--text-dark);
        margin-bottom: 8px;
        word-break: break-all;
    }

    .file-size {
        color: var(--text-light);
        font-size: 14px;
        margin-bottom: 24px;
    }

    .btn-download {
        background: var(--primary);
        color: white;
        border: none;
        padding: 12px 32px;
        border-radius: 40px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-download:hover {
            background: var(--primary-dark);
            transform: translateY(-1px);
        }
</style>

<div class="share-container">
    <div class="share-card">
        <div class="share-header">
            <h3><i class="fas fa-share-alt"></i> File được chia sẻ</h3>
        </div>
        <div class="share-body">
            <div class="file-icon">
                <i class="fas fa-file-alt"></i>
            </div>
            <div class="file-name">@Model.FileName</div>
            <div class="file-size">Kích thước: @(Model.FileSize / 1024) KB</div>
            <form method="post" action="@Url.Action("DownloadShared", "Drive")">
                <input type="hidden" name="token" value="@token" />
                <input type="hidden" name="password" value="@ViewBag.Password" />
                <button type="submit" class="btn-download">
                    <i class="fas fa-download"></i> Tải xuống
                </button>
            </form>
        </div>
    </div>
</div>