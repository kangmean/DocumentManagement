@model List<DocumentManagement.Models.FileModel>

@{
    ViewBag.Title = ViewBag.FolderName;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --primary: #00BCD4;
        --primary-dark: #0097A7;
        --text-dark: #212121;
        --text-light: #666666;
        --bg-gray: #F5F5F5;
        --white: #FFFFFF;
        --border: #E0E0E0;
    }

    .shared-container {
        max-width: 1000px;
        margin: 0 auto;
    }

    .shared-header {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        padding: 40px;
        border-radius: 24px;
        color: white;
        margin-bottom: 30px;
        text-align: center;
        box-shadow: 0 4px 15px rgba(0, 188, 212, 0.2);
    }

        .shared-header h2 {
            font-size: 28px;
            margin-bottom: 8px;
            font-weight: 700;
        }

        .shared-header p {
            opacity: 0.9;
            font-size: 14px;
        }

        .shared-header i {
            font-size: 48px;
            margin-bottom: 16px;
        }

    .file-list {
        background: var(--white);
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid var(--border);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    }

        .file-list th {
            background: #F8F9FA;
            padding: 16px 20px;
            text-align: left;
            font-weight: 600;
            color: var(--text-light);
            border-bottom: 1px solid var(--border);
            font-size: 13px;
        }

        .file-list td {
            padding: 14px 20px;
            border-bottom: 1px solid #F0F0F0;
            color: var(--text-dark);
        }

        .file-list tr:last-child td {
            border-bottom: none;
        }

        .file-list tr:hover {
            background: #F8F9FA;
        }

    .file-icon {
        font-size: 20px;
        margin-right: 12px;
        vertical-align: middle;
    }

    .download-btn {
        background: var(--primary);
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 40px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 500;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

        .download-btn:hover {
            background: var(--primary-dark);
            transform: translateY(-1px);
        }

    .empty-state {
        text-align: center;
        padding: 60px;
        background: var(--white);
        border-radius: 20px;
        color: var(--text-light);
    }

        .empty-state i {
            font-size: 48px;
            margin-bottom: 16px;
            opacity: 0.5;
        }
</style>

<div class="shared-container">
    <div class="shared-header">
        <i class="fas fa-folder-open"></i>
        <h2>@ViewBag.FolderName</h2>
        <p>Được chia sẻ bởi <strong>@ViewBag.OwnerName</strong></p>
    </div>

    @if (Model.Count == 0)
    {
        <div class="empty-state">
            <i class="fas fa-folder-open"></i>
            <p>Thư mục này không có file nào</p>
        </div>
    }
    else
    {
        <div class="file-list">
            <table style="width:100%">
                <thead>
                    <tr>
                        <th>Tên file</th>
                        <th>Kích thước</th>
                        <th>Ngày tải lên</th>
                        <th style="text-align:right">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var file in Model)
                    {
                        string iconClass = file.FileType == "pdf" ? "fa-file-pdf" : "fa-file";
                        string iconColor = file.FileType == "pdf" ? "#DC3545" : "#6C757D";

                        <tr>
                            <td>
                                <i class="fas @iconClass file-icon" style="color: @iconColor"></i>
                                @file.FileName
                            </td>
                            <td>@file.FormattedSize</td>
                            <td>@file.UploadedAt.ToString("dd/MM/yyyy")</td>
                            <td style="text-align:right">
                                <form method="post" action="@Url.Action("DownloadSharedFile", "Drive")" style="display:inline">
                                    <input type="hidden" name="fileId" value="@file.ID" />
                                    <input type="hidden" name="token" value="@ViewBag.Token" />
                                    <button type="submit" class="download-btn">
                                        <i class="fas fa-download"></i> Tải
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>