@{
    ViewBag.Title = "Xác thực";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var token = ViewBag.Token ?? Request.QueryString["token"];
}

<style>
    :root {
        --primary: #00BCD4;
        --primary-dark: #0097A7;
        --text-dark: #212121;
        --text-light: #666666;
        --bg-gray: #F5F5F5;
        --white: #FFFFFF;
        --border: #E0E0E0;
        --error: #DC3545;
    }

    .password-container {
        max-width: 450px;
        margin: 80px auto;
    }

    .password-card {
        background: var(--white);
        border-radius: 24px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .password-header {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        padding: 24px;
        text-align: center;
        color: white;
    }

        .password-header i {
            font-size: 48px;
            margin-bottom: 12px;
        }

        .password-header h3 {
            margin: 0;
            font-size: 20px;
            font-weight: 600;
        }

    .password-body {
        padding: 32px;
    }

    .alert-danger {
        background: #FFEBEE;
        color: var(--error);
        padding: 12px 16px;
        border-radius: 12px;
        margin-bottom: 20px;
        font-size: 14px;
    }

    .form-group {
        margin-bottom: 24px;
    }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            color: var(--text-dark);
        }

        .form-group input {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid var(--border);
            border-radius: 12px;
            font-size: 14px;
            transition: all 0.2s;
        }

            .form-group input:focus {
                outline: none;
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(0, 188, 212, 0.1);
            }

    .btn-submit {
        width: 100%;
        padding: 12px;
        background: var(--primary);
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-submit:hover {
            background: var(--primary-dark);
            transform: translateY(-1px);
        }

    .info-text {
        text-align: center;
        margin-top: 20px;
        color: var(--text-light);
        font-size: 13px;
    }
</style>

<div class="password-container">
    <div class="password-card">
        <div class="password-header">
            <i class="fas fa-folder-lock"></i>
            <h3>Thư mục được bảo vệ</h3>
        </div>
        <div class="password-body">
            @if (!string.IsNullOrEmpty(ViewBag.Error))
            {
                <div class="alert-danger">
                    <i class="fas fa-exclamation-triangle"></i> @ViewBag.Error
                </div>
            }
            <form method="post" action="@Url.Action("VerifyFolderPassword", "Drive")">
                <input type="hidden" name="token" value="@token" />
                <div class="form-group">
                    <label>Nhập mật khẩu để xem nội dung</label>
                    <input type="password" name="password" placeholder="Nhập mật khẩu..." required />
                </div>
                <button type="submit" class="btn-submit">
                    <i class="fas fa-unlock-alt"></i> Xác nhận
                </button>
            </form>
            <div class="info-text">
                <i class="fas fa-info-circle"></i> Thư mục này được bảo vệ bằng mật khẩu
            </div>
        </div>
    </div>
</div>