@model List<DocumentManagement.Models.FileModel>

@{
    ViewBag.Title = "Quản lý file";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .file-item {
        transition: all 0.2s;
    }

        .file-item:hover {
            background-color: #f8f9ff;
        }
</style>

<div class="card">
    <div class="card-header bg-info text-white">
        <h5 class="mb-0"><i class="fas fa-file-alt"></i> Tất cả file trong hệ thống</h5>
    </div>
    <div class="card-body">
        <!-- Form tìm kiếm -->
        <form method="get" action="@Url.Action("Files", "Admin")" class="mb-3">
            <div class="input-group">
                <input type="text" name="search" class="form-control" placeholder="Tìm kiếm theo tên file hoặc người dùng..." value="@ViewBag.Search">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-search"></i> Tìm
                </button>
                @if (!string.IsNullOrEmpty(ViewBag.Search))
                {
                    <a href="@Url.Action("Files", "Admin")" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Xóa
                    </a>
                }
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên file</th>
                        <th>Kích thước</th>
                        <th>Loại</th>
                        <th>Người dùng ID</th>
                        <th>Ngày upload</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var file in Model)
                    {
                        <tr id="file-@file.ID" class="file-item">
                            <td>@file.ID</td>
                            <td>
                                <i class="fas @(file.FileType == "pdf" ? "fa-file-pdf text-danger" :
                                           (file.FileType == "jpg" || file.FileType == "png" ? "fa-file-image text-success" :
                                           (file.FileType == "docx" ? "fa-file-word text-primary" : "fa-file text-secondary")))"></i>
                                @file.FileName
                            </td>
                            <td>@file.FormattedSize</td>
                            <td>@file.FileType</td>
                            <td>@file.UserID</td>
                            <td>@file.UploadedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <button class="btn btn-sm btn-danger delete-file" data-id="@file.ID" data-name="@file.FileName">
                                    <i class="fas fa-trash"></i> Xóa
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.Count == 0)
        {
            <p class="text-muted text-center">Không có file nào</p>
        }
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var deleteButtons = document.querySelectorAll('.delete-file');

        deleteButtons.forEach(function(button) {
            button.addEventListener('click', function(e) {
                e.preventDefault();
                var fileId = this.getAttribute('data-id');
                var fileName = this.getAttribute('data-name');
                var row = document.getElementById('file-' + fileId);

                if (confirm(`Bạn có chắc muốn xóa file "${fileName}"? Hành động này không thể hoàn tác!`)) {
                    var xhr = new XMLHttpRequest();
                    xhr.open('POST', '/Admin/DeleteFile', true);
                    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');

                    xhr.onload = function() {
                        if (xhr.status === 200) {
                            var data = JSON.parse(xhr.responseText);
                            if (data.success) {
                                row.remove();
                                alert('Đã xóa file thành công');
                            } else {
                                alert('Lỗi: ' + data.message);
                            }
                        } else {
                            alert('Lỗi kết nối server');
                        }
                    };

                    xhr.send('fileId=' + fileId);
                }
            });
        });
    });
</script>