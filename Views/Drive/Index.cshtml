@model DocumentManagement.Models.DriveViewModel

@{
    ViewBag.Title = "My Drive";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .sidebar {
        background-color: #f8f9fa;
        min-height: calc(100vh - 150px);
        padding: 20px;
        border-right: 1px solid #dee2e6;
    }

    .storage-info {
        background-color: white;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 20px;
    }

    .storage-bar {
        height: 8px;
        background-color: #e9ecef;
        border-radius: 4px;
        margin: 10px 0;
    }

    .storage-used {
        height: 100%;
        background-color: #4285f4;
        border-radius: 4px;
        width: 35%;
    }

    .toolbar {
        background-color: white;
        padding: 10px 20px;
        border-radius: 8px;
        margin-bottom: 20px;
        border: 1px solid #dee2e6;
    }

        .toolbar button {
            margin-right: 10px;
        }

    .file-item, .folder-item {
        display: flex;
        align-items: center;
        padding: 10px;
        border-bottom: 1px solid #f0f0f0;
    }

        .file-item:hover, .folder-item:hover {
            background-color: #f8f9fa;
        }

    .file-icon, .folder-icon {
        width: 32px;
        text-align: center;
        margin-right: 15px;
        font-size: 20px;
    }

    .file-name, .folder-name {
        flex: 2;
    }

    .file-size {
        width: 100px;
        color: #6c757d;
    }

    .file-date {
        width: 150px;
        color: #6c757d;
    }

    .file-actions, .folder-actions {
        width: 150px;
        text-align: right;
    }

        .file-actions button, .folder-actions button {
            background: none;
            border: none;
            color: #6c757d;
            cursor: pointer;
            margin-left: 10px;
        }

            .file-actions button:hover, .folder-actions button:hover {
                color: #4285f4;
            }

    .starred {
        color: #ffc107;
    }

    .breadcrumb {
        background-color: white;
        padding: 10px 20px;
        border-radius: 8px;
        margin-bottom: 20px;
        border: 1px solid #dee2e6;
    }

    .breadcrumb-item a {
        color: #4285f4;
        text-decoration: none;
    }

    .folder-color-dot {
        width: 12px;
        height: 12px;
        border-radius: 2px;
        display: inline-block;
        margin-right: 8px;
    }

    @@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.file-item, .folder-item {
    animation: fadeInUp 0.3s ease-out;
}

</style>

<div class="row">
    <!-- Modal tạo folder -->
    <div class="modal fade" id="newFolderModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Tạo thư mục mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="text" id="folderName" class="form-control" placeholder="Nhập tên thư mục">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-primary" id="btnCreateFolder">Tạo</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal đổi màu folder -->
    <div class="modal fade" id="colorModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-palette"></i> Đổi màu thư mục</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="colorFolderId">
                    <div class="d-flex justify-content-around">
                        <button class="btn-color" data-color="#4285F4" style="background:#4285F4; width:40px; height:40px; border-radius:50%; border:none;"></button>
                        <button class="btn-color" data-color="#EA4335" style="background:#EA4335; width:40px; height:40px; border-radius:50%; border:none;"></button>
                        <button class="btn-color" data-color="#FBBC05" style="background:#FBBC05; width:40px; height:40px; border-radius:50%; border:none;"></button>
                        <button class="btn-color" data-color="#34A853" style="background:#34A853; width:40px; height:40px; border-radius:50%; border:none;"></button>
                        <button class="btn-color" data-color="#9C27B0" style="background:#9C27B0; width:40px; height:40px; border-radius:50%; border:none;"></button>
                        <button class="btn-color" data-color="#FF6D00" style="background:#FF6D00; width:40px; height:40px; border-radius:50%; border:none;"></button>
                        <button class="btn-color" data-color="#808080" style="background:#808080; width:40px; height:40px; border-radius:50%; border:none;"></button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal chia sẻ file -->
    <div class="modal fade" id="shareModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-share-alt"></i> Chia sẻ file</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="shareFileId">
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu (tùy chọn)</label>
                        <input type="text" id="sharePassword" class="form-control" placeholder="Để trống nếu không cần mật khẩu">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ngày hết hạn (tùy chọn)</label>
                        <input type="datetime-local" id="shareExpiry" class="form-control">
                    </div>
                    <div id="shareResult" style="display:none;" class="alert alert-success">
                        <strong>Link chia sẻ:</strong><br>
                        <input type="text" id="shareUrl" class="form-control" readonly>
                        <button class="btn btn-sm btn-primary mt-2" onclick="copyShareUrl()">Copy link</button>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="button" class="btn btn-primary" id="btnCreateShare">Tạo link</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Sidebar trái -->
    <div class="col-md-3">
        <div class="sidebar">
            <div class="storage-info">
                <h6>Dung lượng</h6>
                <div class="d-flex justify-content-between">
                    <span>Đã dùng</span>
                    <span>5.4 GB / 15 GB</span>
                </div>
                <div class="storage-bar">
                    <div class="storage-used"></div>
                </div>
            </div>

            <div class="list-group">
                <a href="#" class="list-group-item list-group-item-action active">
                    <i class="fas fa-cloud"></i> My Drive
                </a>
                <a href="@Url.Action("Starred", "Drive")" class="list-group-item list-group-item-action">
                    <i class="fas fa-star"></i> Starred
                </a>
                <a href="@Url.Action("Trash", "Drive")" class="list-group-item list-group-item-action">
                    <i class="fas fa-trash"></i> Trash
                </a>
            </div>
        </div>
    </div>

    <!-- Nội dung chính -->
    <div class="col-md-9">
        <!-- Breadcrumb -->
        <nav class="breadcrumb-nav">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Drive")">My Drive</a></li>
                @foreach (var folder in Model.Breadcrumb)
                {
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Drive", new { folderId = folder.ID })">@folder.FolderName</a></li>
                }
            </ol>
        </nav>

        <!-- Toolbar -->
        <div class="toolbar">
            @using (Html.BeginForm("Upload", "Drive", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                <input type="file" name="files" id="fileUpload" multiple style="display: none;" onchange="this.form.submit()" />
                <input type="hidden" name="folderId" value="@Model.CurrentFolderID" />
                <button type="button" class="btn btn-primary btn-sm" onclick="document.getElementById('fileUpload').click();" data-bs-toggle="tooltip" title="Upload file">
                    <i class="fas fa-upload"></i> Upload
                </button>
            }
            <button type="button" class="btn btn-success btn-sm" id="btnNewFolder" data-bs-toggle="tooltip" title="Tạo thư mục mới">
                <i class="fas fa-folder-plus"></i> New Folder
            </button>
            <button class="btn btn-secondary btn-sm" data-bs-toggle="tooltip" title="Tải xuống">
                <i class="fas fa-download"></i> Download
            </button>
            <button class="btn btn-danger btn-sm" data-bs-toggle="tooltip" title="Xóa">
                <i class="fas fa-trash"></i> Delete
            </button>
            <button class="btn btn-info btn-sm" data-bs-toggle="tooltip" title="Chia sẻ">
                <i class="fas fa-share-alt"></i> Share
            </button>
        </div>

        <!-- Filter và Sort -->
        <div class="row mt-2 mb-3">
            <div class="col-md-6">
                <select id="filterType" class="form-select form-select-sm">
                    <option value="All">📁 Tất cả</option>
                    <option value="pdf">📄 PDF</option>
                    <option value="jpg">🖼️ Hình ảnh</option>
                    <option value="png">🖼️ Hình ảnh</option>
                    <option value="docx">📝 Tài liệu Word</option>
                    <option value="xlsx">📊 Excel</option>
                </select>
            </div>
            <div class="col-md-6">
                <select id="sortBy" class="form-select form-select-sm">
                    <option value="name_asc">📝 Tên A-Z</option>
                    <option value="name_desc">📝 Tên Z-A</option>
                    <option value="size_asc">📏 Kích thước tăng dần</option>
                    <option value="size_desc">📏 Kích thước giảm dần</option>
                    <option value="date_desc">🕐 Mới nhất</option>
                    <option value="date_asc">🕐 Cũ nhất</option>
                </select>
            </div>
        </div>

        <!-- Danh sách thư mục -->
        <h6 class="mt-3">Thư mục</h6>
        <div class="folder-list">
            @foreach (var folder in Model.Folders)
            {
                <div class="folder-item" style="cursor: pointer;" onclick="window.location.href='@Url.Action("Index", "Drive", new { folderId = folder.ID })'">
                    <div class="folder-icon">
                        <i class="fas fa-folder" style="color: @folder.FolderColor;"></i>
                    </div>
                    <div class="folder-name">
                        <span class="folder-color-dot" style="background-color: @folder.FolderColor;"></span>
                        @folder.FolderName
                    </div>
                    <div class="file-date">
                        @folder.CreatedAt.ToString("dd/MM/yyyy")
                    </div>
                    <div class="folder-actions">
                        <button class="change-color" data-id="@folder.ID" title="Đổi màu">
                            <i class="fas fa-palette"></i>
                        </button>
                        <button title="Download" disabled style="opacity:0.5;"><i class="fas fa-download"></i></button>
                        <button title="Chia sẻ"><i class="fas fa-share-alt"></i></button>
                        <button title="Xóa"><i class="fas fa-trash"></i></button>
                    </div>
                </div>
            }
        </div>

        <!-- Danh sách file -->
        <h6 class="mt-4">File</h6>
        <div class="file-list">
            @foreach (var file in Model.Files)
            {
                <div class="file-item">
                    <div class="file-icon">
                        @if (file.FileType == "pdf")
                        {
                            <i class="fas fa-file-pdf text-danger"></i>
                        }
                        else if (file.FileType == "jpg" || file.FileType == "png")
                        {
                            <i class="fas fa-file-image text-success"></i>
                        }
                        else if (file.FileType == "docx" || file.FileType == "doc")
                        {
                            <i class="fas fa-file-word text-primary"></i>
                        }
                        else if (file.FileType == "xlsx" || file.FileType == "xls")
                        {
                            <i class="fas fa-file-excel text-success"></i>
                        }
                        else
                        {
                            <i class="fas fa-file text-secondary"></i>
                        }
                    </div>
                    <div class="file-name">
                        @if (file.IsStarred)
                        {
                            <i class="fas fa-star starred"></i>
                        }
                        @file.FileName
                    </div>
                    <div class="file-size">@file.FormattedSize</div>
                    <div class="file-date">@file.UploadedAt.ToString("dd/MM/yyyy HH:mm")</div>
                    <div class="file-actions">
                        <button class="star-file" data-id="@file.ID" title="Đánh dấu sao">
                            <i class="fas fa-star @(file.IsStarred ? "text-warning" : "")"></i>
                        </button>
                        @if (file.FileType == "pdf")
                        {
                            <a href="@Url.Action("PreviewPDF", "Drive", new { id = file.ID })" title="Xem trước" style="color: #6c757d;" target="_blank">
                                <i class="fas fa-eye"></i>
                            </a>
                        }
                        <a href="@Url.Action("Download", "Drive", new { id = file.ID })" title="Download" style="color: #6c757d;">
                            <i class="fas fa-download"></i>
                        </a>
                        <button class="share-file" data-id="@file.ID" title="Chia sẻ">
                            <i class="fas fa-share-alt"></i>
                        </button>
                        <button class="delete-file" data-id="@file.ID" title="Xóa">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<script>
    // Đợi trang load xong
    document.addEventListener('DOMContentLoaded', function () {

        // 1. XỬ LÝ TOOLTIP
        var tooltips = document.querySelectorAll('[data-bs-toggle="tooltip"]');
        if (typeof bootstrap !== 'undefined') {
            tooltips.forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        }

        // 2. XỬ LÝ NÚT XÓA
        var deleteButtons = document.querySelectorAll('.delete-file');
        console.log('Tìm thấy ' + deleteButtons.length + ' nút xóa');

        deleteButtons.forEach(function (button) {
            button.addEventListener('click', function (e) {
                e.preventDefault();

                var fileId = this.getAttribute('data-id');
                var row = this.closest('.file-item');

                if (confirm('Bạn có chắc muốn xóa file này?')) {
                    // Gửi request xóa
                    var xhr = new XMLHttpRequest();
                    xhr.open('POST', '/Drive/Delete', true);
                    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');

                    xhr.onload = function () {
                        if (xhr.status === 200) {
                            var data = JSON.parse(xhr.responseText);
                            if (data.success) {
                                row.remove(); // Xóa dòng khỏi giao diện
                            } else {
                                alert('Lỗi: ' + data.message);
                            }
                        } else {
                            alert('Lỗi kết nối server');
                        }
                    };

                    xhr.send('id=' + fileId);
                }
            });
        });

        // 3. XỬ LÝ UPLOAD FILE (khi chọn file)
        var fileUpload = document.getElementById('fileUpload');
        if (fileUpload) {
            fileUpload.addEventListener('change', function () {
                this.form.submit();
            });
        }

    });

   // Mở modal tạo folder
document.getElementById('btnNewFolder').addEventListener('click', function() {
    var modal = new bootstrap.Modal(document.getElementById('newFolderModal'));
    modal.show();
});

// Xử lý tạo folder
document.getElementById('btnCreateFolder').addEventListener('click', function() {
    var folderName = document.getElementById('folderName').value;
    var currentFolderId = '@Model.CurrentFolderID';

    if (!folderName) {
        alert('Vui lòng nhập tên thư mục');
        return;
    }

    // Gửi request tạo folder
    var xhr = new XMLHttpRequest();
    xhr.open('POST', '/Drive/CreateFolder', true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');

    xhr.onload = function() {
        if (xhr.status === 200) {
            var data = JSON.parse(xhr.responseText);
            if (data.success) {
                location.reload();
            } else {
                alert(data.message);
            }
        }
    };

    xhr.send('folderName=' + encodeURIComponent(folderName) + '&folderId=' + currentFolderId);
});

    // XỬ LÝ ĐÁNH DẤU SAO
    var starButtons = document.querySelectorAll('.star-file');
    starButtons.forEach(function (button) {
        button.addEventListener('click', function (e) {
            e.preventDefault();

            var fileId = this.getAttribute('data-id');
            var starIcon = this.querySelector('i');

            var xhr = new XMLHttpRequest();
            xhr.open('POST', '/Drive/ToggleStar', true);
            xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');

            xhr.onload = function () {
                if (xhr.status === 200) {
                    var data = JSON.parse(xhr.responseText);
                    if (data.success) {
                        if (data.isStarred) {
                            starIcon.classList.add('text-warning');
                        } else {
                            starIcon.classList.remove('text-warning');
                        }
                    }
                }
            };

            xhr.send('id=' + fileId);
        });
    });

    // XỬ LÝ FILTER VÀ SORT
document.getElementById('filterType').addEventListener('change', function() {
    applyFilterAndSort();
});

document.getElementById('sortBy').addEventListener('change', function() {
    applyFilterAndSort();
});

function applyFilterAndSort() {
    var filter = document.getElementById('filterType').value;
    var sortValue = document.getElementById('sortBy').value;

    var sort = 'name';
    var order = 'asc';

    switch(sortValue) {
        case 'name_asc':
            sort = 'name';
            order = 'asc';
            break;
        case 'name_desc':
            sort = 'name';
            order = 'desc';
            break;
        case 'size_asc':
            sort = 'size';
            order = 'asc';
            break;
        case 'size_desc':
            sort = 'size';
            order = 'desc';
            break;
        case 'date_desc':
            sort = 'date';
            order = 'desc';
            break;
        case 'date_asc':
            sort = 'date';
            order = 'asc';
            break;
    }

    var currentFolderId = '@Model.CurrentFolderID';
    window.location.href = '/Drive/Index?folderId=' + currentFolderId + '&filter=' + filter + '&sort=' + sort + '&order=' + order;
    }

    // Highlight đúng option khi load trang
    window.addEventListener('DOMContentLoaded', function () {
        var urlParams = new URLSearchParams(window.location.search);
        var currentFilter = urlParams.get('filter') || 'All';
        var currentSort = urlParams.get('sort') || 'name';
        var currentOrder = urlParams.get('order') || 'asc';

        document.getElementById('filterType').value = currentFilter;
        document.getElementById('sortBy').value = currentSort + '_' + currentOrder;
    });

    // XỬ LÝ CHIA SẺ
    var shareButtons = document.querySelectorAll('.share-file');
    shareButtons.forEach(function (button) {
        button.addEventListener('click', function () {
            var fileId = this.getAttribute('data-id');
            document.getElementById('shareFileId').value = fileId;
            document.getElementById('sharePassword').value = '';
            document.getElementById('shareExpiry').value = '';
            document.getElementById('shareResult').style.display = 'none';
            var modal = new bootstrap.Modal(document.getElementById('shareModal'));
            modal.show();
        });
    });

    document.getElementById('btnCreateShare').addEventListener('click', function () {
        var fileId = document.getElementById('shareFileId').value;
        var password = document.getElementById('sharePassword').value;
        var expiry = document.getElementById('shareExpiry').value;

        var xhr = new XMLHttpRequest();
        xhr.open('POST', '/Drive/CreateShareLink', true);
        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');

        xhr.onload = function () {
            if (xhr.status === 200) {
                var data = JSON.parse(xhr.responseText);
                if (data.success) {
                    document.getElementById('shareUrl').value = data.url;
                    document.getElementById('shareResult').style.display = 'block';
                } else {
                    alert(data.message);
                }
            }
        };

        xhr.send('fileId=' + fileId + '&password=' + encodeURIComponent(password) + '&expiryDate=' + encodeURIComponent(expiry));
    });

    function copyShareUrl() {
        var urlInput = document.getElementById('shareUrl');
        urlInput.select();
        document.execCommand('copy');
        alert('Đã copy link chia sẻ!');
    }

    // XỬ LÝ ĐỔI MÀU FOLDER
    var colorButtons = document.querySelectorAll('.change-color');
    colorButtons.forEach(function (button) {
        button.addEventListener('click', function (e) {
            e.preventDefault();
            e.stopPropagation();
            var folderId = this.getAttribute('data-id');
            document.getElementById('colorFolderId').value = folderId;
            var modal = new bootstrap.Modal(document.getElementById('colorModal'));
            modal.show();
        });
    });

    document.querySelectorAll('.btn-color').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var folderId = document.getElementById('colorFolderId').value;
            var color = this.getAttribute('data-color');

            var xhr = new XMLHttpRequest();
            xhr.open('POST', '/Drive/ChangeFolderColor', true);
            xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');

            xhr.onload = function () {
                if (xhr.status === 200) {
                    var data = JSON.parse(xhr.responseText);
                    if (data.success) {
                        location.reload();
                    }
                }
            };

            xhr.send('folderId=' + folderId + '&color=' + color);
        });
    });

</script>