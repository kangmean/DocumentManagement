@model List<DocumentManagement.Models.FileModel>

@{
    ViewBag.Title = "Starred";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card">
    <div class="card-header bg-warning">
        <h5 class="mb-0"><i class="fas fa-star"></i> File đã đánh dấu sao</h5>
    </div>
    <div class="card-body">
        @if (Model.Count == 0)
        {
            <p class="text-muted text-center">Chưa có file nào được đánh dấu sao</p>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Tên file</th>
                        <th>Kích thước</th>
                        <th>Ngày upload</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var file in Model)
                    {
                        <tr>
                            <td>
                                <i class="fas fa-star text-warning me-2"></i>
                                @file.FileName
                            </td>
                            <td>@file.FormattedSize</td>
                            <td>@file.UploadedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <a href="@Url.Action("Download", "Drive", new { id = file.ID })" class="btn btn-sm btn-primary">
                                    <i class="fas fa-download"></i> Download
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>