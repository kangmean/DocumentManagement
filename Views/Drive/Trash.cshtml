@model List<DocumentManagement.Models.FileModel>

@{
    ViewBag.Title = "Thùng rác";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card">
    <div class="card-header bg-danger text-white">
        <h5 class="mb-0"><i class="fas fa-trash"></i> Thùng rác</h5>
    </div>
    <div class="card-body">
        @if (Model.Count == 0)
        {
            <p class="text-muted text-center">Thùng rác trống</p>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Tên file</th>
                        <th>Kích thước</th>
                        <th>Ngày xóa</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var file in Model)
                    {
                        <tr id="file-@file.ID">
                            <td>
                                <i class="fas fa-file me-2"></i>
                                @file.FileName
                            </td>
                            <td>@file.FormattedSize</td>
                            <td>@(file.DeletedAt?.ToString("dd/MM/yyyy HH:mm") ?? "")</td>
                            <td>
                                <button class="btn btn-sm btn-success restore-file" data-id="@file.ID">
                                    <i class="fas fa-trash-restore"></i> Khôi phục
                                </button>
                                <button class="btn btn-sm btn-danger delete-forever" data-id="@file.ID">
                                    <i class="fas fa-trash-alt"></i> Xóa vĩnh viễn
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {

        // Khôi phục file
        var restoreButtons = document.querySelectorAll('.restore-file');
        restoreButtons.forEach(function (button) {
            button.addEventListener('click', function () {
                var id = this.getAttribute('data-id');
                var row = document.getElementById('file-' + id);

                if (confirm('Khôi phục file này?')) {
                    var xhr = new XMLHttpRequest();
                    xhr.open('POST', '/Drive/Restore', true);
                    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');

                    xhr.onload = function () {
                        if (xhr.status === 200) {
                            var data = JSON.parse(xhr.responseText);
                            if (data.success) {
                                row.remove();
                            } else {
                                alert('Lỗi: ' + data.message);
                            }
                        }
                    };

                    xhr.send('id=' + id);
                }
            });
        });

        // Xóa vĩnh viễn
        var deleteButtons = document.querySelectorAll('.delete-forever');
        deleteButtons.forEach(function (button) {
            button.addEventListener('click', function () {
                var id = this.getAttribute('data-id');
                var row = document.getElementById('file-' + id);

                if (confirm('Xóa vĩnh viễn file này? Không thể khôi phục!')) {
                    var xhr = new XMLHttpRequest();
                    xhr.open('POST', '/Drive/DeleteForever', true);
                    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');

                    xhr.onload = function () {
                        if (xhr.status === 200) {
                            var data = JSON.parse(xhr.responseText);
                            if (data.success) {
                                row.remove();
                            } else {
                                alert('Lỗi: ' + data.message);
                            }
                        }
                    };

                    xhr.send('id=' + id);
                }
            });
        });

    });
</script>